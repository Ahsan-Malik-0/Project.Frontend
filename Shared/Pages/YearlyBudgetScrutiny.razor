@using Project.Frontend.Model
@using Project.Frontend.Model.DTOs

@inject YearlyBudgetScrutinyServices scrutinyService
@inject IJSRuntime JS

<!-- ===== LOADING ===== -->
@if (isLoading)
{
    <div class="text-center text-muted py-5">
        <div class="spinner-border spinner-border-sm mb-2"></div>
        <p class="mb-0">Loading yearly budgets...</p>
    </div>
}
else if (yearlyBudgets.Count == 0)
{
    <div class="text-center text-muted py-5">
        <i class="bi bi-inbox fs-1 d-block mb-2"></i>
        <p class="mb-0">No yearly budgets found.</p>
    </div>
}
else
{
    <!-- ===== BUDGET CARDS ===== -->
    <div class="row g-4">
        @foreach (var budget in yearlyBudgets)
        {
            bool isAllotted = budget.AllotedAmount > 0;

            <div class="col-12 col-md-6 col-xl-4">
                <div class="card border-0 shadow-sm h-100">

                    <!-- Header -->
                    <div class="card-header bg-white border-bottom d-flex align-items-center justify-content-between py-3">
                        <span class="fw-semibold">
                            @(budget.Society?.Name ?? "Unknown Society")
                            <span class="text-muted small fw-normal ms-1">(@budget.Session)</span>
                        </span>
                        <span class="badge @(isAllotted ? "bg-success" : "bg-secondary")">
                            @(isAllotted ? "Allotted" : "Not Allotted")
                        </span>
                    </div>

                    <!-- Body -->
                    <div class="card-body">
                        <p class="mb-2 small">
                            <span class="text-muted">Requested Amount:</span>
                            <span class="fw-semibold text-primary ms-1">Rs @budget.RequestedAmount.ToString("N0")</span>
                        </p>
                        <p class="mb-2 small">
                            <span class="text-muted">Requested Date:</span>
                            <span class="fw-semibold ms-1">@budget.RequestedDate.ToString("dd MMM yyyy")</span>
                        </p>

                        @if (isAllotted)
                        {
                            <p class="mb-2 small">
                                <span class="text-muted">Allotted Amount:</span>
                                <span class="fw-semibold text-success ms-1">Rs @budget.AllotedAmount.ToString("N0")</span>
                            </p>
                            <p class="mb-2 small">
                                <span class="text-muted">Allotted Date:</span>
                                <span class="fw-semibold ms-1">
                                    @(budget.AllotedDate != default ? budget.AllotedDate.ToString("dd MMM yyyy") : "—")
                                </span>
                            </p>
                        }
                        else
                        {
                            <p class="mb-2 small text-muted">Allotted Amount: <span class="fw-semibold">Not allotted yet</span></p>
                            <p class="mb-2 small text-muted">Allotted Date: <span class="fw-semibold">—</span></p>
                        }

                        <p class="mb-0 small">
                            <span class="text-muted">Credits (Remaining):</span>
                            <span class="fw-semibold text-warning ms-1">
                                @(budget.Credits > 0 ? "Rs " + budget.Credits.ToString("N0") : "—")
                            </span>
                        </p>
                    </div>

                    <!-- Footer -->
                    <div class="card-footer bg-white border-top py-3">
                        <div class="row g-2">

                            <!-- Row 1: View Comments + View Details (50/50) -->
                            <div class="col-6">
                                <button class="btn btn-outline-secondary btn-sm w-100"
                                        @onclick="() => OpenCommentsModal(budget)">
                                    <i class="bi bi-chat-left-text me-1"></i> Comments
                                </button>
                            </div>
                            <div class="col-6">
                                <button class="btn btn-outline-primary btn-sm w-100"
                                        @onclick="() => OpenDetailsModal(budget)">
                                    <i class="bi bi-eye me-1"></i> View Details
                                </button>
                            </div>

                            <!-- Row 2: Approve (Student Affairs only, 100%) -->
                            @if (Role == "studentAffairs")
                            {
                                <div class="col-12">
                                    <button class="btn btn-success btn-sm w-100"
                                            @onclick="() => OpenApproveModal(budget)">
                                        <i class="bi bi-check-circle me-1"></i> Approve Yearly Budget
                                    </button>
                                </div>
                            }

                        </div>
                    </div>

                </div>
            </div>
        }
    </div>
}


<!-- ===== MODAL: View Details ===== -->
@if (showDetailsModal && activeBudget != null)
{
    <div class="modal fade show d-block" tabindex="-1" style="background:rgba(0,0,0,0.5)">
        <div class="modal-dialog modal-xl modal-dialog-centered modal-dialog-scrollable">
            <div class="modal-content border-0 shadow">
                <div class="modal-header border-bottom">
                    <h6 class="modal-title fw-bold">
                        Yearly Budget — @(activeBudget.Society?.Name) (@activeBudget.Session)
                    </h6>
                    <button class="btn-close" @onclick="CloseAllModals"></button>
                </div>
                <div class="modal-body p-4">

                    <!-- Summary Cards (same style as HandleYearlyBudget reference) -->
                    <div class="row g-3 mb-4">
                        <div class="col-6 col-md-3">
                            <div class="card h-100 border shadow-sm">
                                <div class="card-body">
                                    <p class="text-muted small text-uppercase fw-semibold mb-1"
                                       style="font-size:0.7rem;letter-spacing:0.06em;">Requested Amount</p>
                                    <h5 class="fw-bold text-primary mb-1">Rs @activeBudget.RequestedAmount.ToString("N0")</h5>
                                    <p class="text-muted mb-0" style="font-size:0.75rem;">
                                        @activeBudget.RequestedDate.ToString("dd MMM yyyy")
                                    </p>
                                </div>
                            </div>
                        </div>
                        <div class="col-6 col-md-3">
                            <div class="card h-100 border shadow-sm">
                                <div class="card-body">
                                    <p class="text-muted small text-uppercase fw-semibold mb-1"
                                       style="font-size:0.7rem;letter-spacing:0.06em;">Allotted Amount</p>
                                    <h5 class="fw-bold text-success mb-1">
                                        @(activeBudget.AllotedAmount > 0 ? "Rs " + activeBudget.AllotedAmount.ToString("N0") : "—")
                                    </h5>
                                    <p class="text-muted mb-0" style="font-size:0.75rem;">
                                        @(activeBudget.AllotedDate != default
                                            ? activeBudget.AllotedDate.ToString("dd MMM yyyy")
                                            : "Not allotted yet")
                                    </p>
                                </div>
                            </div>
                        </div>
                        <div class="col-6 col-md-3">
                            <div class="card h-100 border shadow-sm">
                                <div class="card-body">
                                    <p class="text-muted small text-uppercase fw-semibold mb-1"
                                       style="font-size:0.7rem;letter-spacing:0.06em;">Credits</p>
                                    <h5 class="fw-bold text-warning mb-1">
                                        @(activeBudget.Credits > 0 ? "Rs " + activeBudget.Credits.ToString("N0") : "—")
                                    </h5>
                                </div>
                            </div>
                        </div>
                        <div class="col-6 col-md-3">
                            <div class="card h-100 border shadow-sm">
                                <div class="card-body">
                                    <p class="text-muted small text-uppercase fw-semibold mb-1"
                                       style="font-size:0.7rem;letter-spacing:0.06em;">Total Events</p>
                                    <h5 class="fw-bold mb-1">@(activeBudget.YearlyEvents?.Count ?? 0)</h5>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Events Accordion -->
                    <div class="d-flex align-items-center gap-2 mb-3">
                        <h5 class="fw-bold mb-0">Events</h5>
                        <span class="badge bg-primary bg-opacity-10 text-primary fw-semibold">
                            @(activeBudget.YearlyEvents?.Count ?? 0) planned
                        </span>
                    </div>

                    @if (activeBudget.YearlyEvents == null || !activeBudget.YearlyEvents.Any())
                    {
                        <p class="text-center text-muted small">No events planned for this session.</p>
                    }
                    else
                    {
                        <div class="accordion">
                            @foreach (var ev in activeBudget.YearlyEvents)
                            {
                                bool isOpen = expandedEvents.Contains(ev.Id);
                                <div class="accordion-item border mb-2 rounded shadow-sm overflow-hidden">
                                    <h2 class="accordion-header">
                                        <button class="accordion-button @(isOpen ? "" : "collapsed") fw-semibold"
                                                type="button"
                                                @onclick="() => ToggleEvent(ev.Id)">
                                            <div class="d-flex align-items-center justify-content-between w-100 flex-wrap gap-2 pe-2">
                                                <span>@ev.Name</span>
                                                <div class="d-flex align-items-center gap-3 text-muted small fw-normal">
                                                    <span><i class="bi bi-calendar3 me-1"></i>@ev.EstimateMonth</span>
                                                    @if (ev.EstimateAmount.HasValue)
                                                    {
                                                        <span class="text-success fw-semibold">
                                                            Rs @ev.EstimateAmount.Value.ToString("N0")
                                                        </span>
                                                    }
                                                    <span class="badge bg-secondary bg-opacity-10 text-secondary fw-normal">
                                                        @(ev.YearlyEventRequirements?.Count ?? 0) req(s)
                                                    </span>
                                                </div>
                                            </div>
                                        </button>
                                    </h2>
                                    @if (isOpen)
                                    {
                                        <div class="accordion-collapse show">
                                            <div class="accordion-body p-0">
                                                @if (ev.YearlyEventRequirements == null || !ev.YearlyEventRequirements.Any())
                                                {
                                                    <p class="text-center text-muted py-3 mb-0 small">No requirements added.</p>
                                                }
                                                else
                                                {
                                                    <div class="table-responsive">
                                                        <table class="table table-hover table-sm align-middle mb-0">
                                                            <thead class="table-light">
                                                                <tr>
                                                                    <th class="text-muted small ps-3" style="width:2.5rem;">#</th>
                                                                    <th class="text-muted small">Requirement</th>
                                                                    <th class="text-muted small">Estimate Price</th>
                                                                </tr>
                                                            </thead>
                                                            <tbody>
                                                                @{ int ri = 1; }
                                                                @foreach (var req in ev.YearlyEventRequirements)
                                                                {
                                                                    <tr>
                                                                        <td class="text-muted ps-3">@ri</td>
                                                                        <td>@req.Name</td>
                                                                        <td class="text-success fw-semibold">
                                                                            @(req.EstimatePrice.HasValue
                                                                                ? "Rs " + req.EstimatePrice.Value.ToString("N0")
                                                                                : "—")
                                                                        </td>
                                                                    </tr>
                                                                    ri++;
                                                                }
                                                            </tbody>
                                                        </table>
                                                    </div>
                                                }
                                            </div>
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    }

                </div>
                <div class="modal-footer border-top">
                    <button class="btn btn-secondary btn-sm" @onclick="CloseAllModals">Close</button>
                </div>
            </div>
        </div>
    </div>
}


<!-- ===== MODAL: Comments (chat style) ===== -->
@if (showCommentsModal && activeBudget != null)
{
    <div class="modal fade show d-block" tabindex="-1" style="background:rgba(0,0,0,0.5)">
        <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable" style="max-width:560px;">
            <div class="modal-content border-0 shadow">
                <div class="modal-header border-bottom">
                    <h6 class="modal-title fw-bold">
                        <i class="bi bi-chat-left-text me-2"></i>
                        Comments — @(activeBudget.Society?.Name) (@activeBudget.Session)
                    </h6>
                    <button class="btn-close" @onclick="CloseAllModals"></button>
                </div>

                <!-- Chat Body -->
                <div class="modal-body" style="max-height:420px;overflow-y:auto;">

                    @if (isLoadingComments)
                    {
                        <div class="text-center text-muted py-4">
                            <div class="spinner-border spinner-border-sm mb-2"></div>
                            <p class="mb-0">Loading comments...</p>
                        </div>
                    }
                    else if (scrutinyDetails.Count == 0)
                    {
                        <div class="text-center text-muted py-4">
                            <i class="bi bi-chat-left fs-2 d-block mb-2"></i>
                            <p class="mb-0 small">No comments yet. Be the first to write one.</p>
                        </div>
                    }
                    else
                    {
                        @foreach (var comment in scrutinyDetails.OrderBy(c => c.CommentDate))
                        {
                            bool isOwn = comment.AdministrationName == userName
                                      && comment.AdministrationRole == Role;

                            <div class="mb-3 p-3 rounded border bg-light">
                                <!-- Name -->
                                <div class="fw-semibold text-primary small mb-0">
                                    @comment.AdministrationName
                                </div>
                                <!-- Role -->
                                <div class="text-muted" style="font-size:0.72rem;">@comment.AdministrationRole</div>
                                <!-- Comment -->
                                <p class="mb-1 mt-2 fw-semibold">@comment.AdministrationComment</p>
                                <!-- Date + Delete -->
                                <div class="d-flex align-items-center justify-content-between">
                                    <span class="text-muted" style="font-size:0.72rem;">
                                        @comment.CommentDate.ToString("dd MMM yyyy, hh:mm tt")
                                    </span>
                                    @if (isOwn)
                                    {
                                        <button class="btn btn-link btn-sm text-danger p-0"
                                                style="font-size:0.75rem;"
                                                @onclick="() => HandleDeleteComment(comment.Id)">
                                            <i class="bi bi-trash me-1"></i> Delete
                                        </button>
                                    }
                                </div>
                            </div>
                        }
                    }

                </div>

                <!-- Write Comment -->
                <div class="border-top p-3">
                    <div class="mb-2">
                        <textarea class="form-control form-control-sm"
                                  rows="3"
                                  placeholder="Write a comment..."
                                  @bind="newComment"></textarea>
                    </div>
                    <div class="d-flex justify-content-end">
                        <button class="btn btn-primary btn-sm px-4"
                                disabled="@isSendingComment"
                                @onclick="HandleAddComment">
                            @if (isSendingComment)
                            {
                                <span class="spinner-border spinner-border-sm me-1"></span>
                            }
                            <i class="bi bi-send me-1"></i> Send
                        </button>
                    </div>
                </div>

            </div>
        </div>
    </div>
}


<!-- ===== MODAL: Approve Yearly Budget (Student Affairs only) ===== -->
@if (showApproveModal && activeBudget != null)
{
    <div class="modal fade show d-block" tabindex="-1" style="background:rgba(0,0,0,0.5)">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow">
                <div class="modal-header border-bottom">
                    <h6 class="modal-title fw-bold">
                        <i class="bi bi-check-circle text-success me-2"></i>Approve Yearly Budget
                    </h6>
                    <button class="btn-close" @onclick="CloseAllModals"></button>
                </div>
                <div class="modal-body">

                    <!-- Requested amount info banner -->
                    <div class="alert alert-info py-2 small mb-4">
                        <i class="bi bi-info-circle me-1"></i>
                        <strong>Requested Amount:</strong> Rs @activeBudget.RequestedAmount.ToString("N0")
                    </div>

                    <!-- Allotted Date (disabled, today) -->
                    <div class="mb-3">
                        <label class="form-label fw-semibold small">Allotted Date</label>
                        <input class="form-control"
                               value="@DateTime.Today.ToString("dd MMM yyyy")"
                               disabled />
                        <div class="form-text text-muted">Auto-set to today's date.</div>
                    </div>

                    <!-- Allotted Amount -->
                    <div class="mb-1">
                        <label class="form-label fw-semibold small">
                            Allotted Amount <span class="text-danger">*</span>
                        </label>
                        <div class="input-group">
                            <span class="input-group-text">Rs</span>
                            <input type="number" class="form-control" min="0"
                                   @bind="approveAllotedAmount"
                                   placeholder="0" />
                        </div>
                    </div>

                </div>
                <div class="modal-footer border-top">
                    <button class="btn btn-outline-secondary btn-sm" @onclick="CloseAllModals">Cancel</button>
                    <button class="btn btn-success btn-sm px-4"
                            disabled="@isActing"
                            @onclick="HandleApprove">
                        @if (isActing)
                        {
                            <span class="spinner-border spinner-border-sm me-1"></span>
                        }
                        Approve
                    </button>
                </div>
            </div>
        </div>
    </div>
}


@code {
    [Parameter] public Guid Id { get; set; }
    [Parameter] public string? Role { get; set; }

    // ── Data ─────────────────────────────────────────────────
    private bool isLoading = false;
    private bool isLoadingComments = false;
    private bool isSendingComment = false;
    private bool isActing = false;

    private List<YearlyBudget> yearlyBudgets = new();
    private List<ViewScrutinyDetailsDto> scrutinyDetails = new();

    // ── Active state ─────────────────────────────────────────
    private YearlyBudget? activeBudget;
    private HashSet<Guid> expandedEvents = new();
    private string newComment = "";
    private decimal approveAllotedAmount = 0;
    private string userName = ""; // populated from Id + Role for own-comment check

    // ── Modal flags ──────────────────────────────────────────
    private bool showDetailsModal = false;
    private bool showCommentsModal = false;
    private bool showApproveModal = false;

    // ── Init ─────────────────────────────────────────────────
    protected override async Task OnInitializedAsync()
    {
        isLoading = true;
        try
        {
            yearlyBudgets = await scrutinyService.GetYearlyBudgetScrutiny();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error fetching yearly budgets: {ex.Message}");
            await JS.InvokeVoidAsync("alert", $"Error fetching yearly budgets: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    // ── Modal Openers ────────────────────────────────────────
    private void OpenDetailsModal(YearlyBudget budget)
    {
        activeBudget = budget;
        expandedEvents.Clear();
        showDetailsModal = true;
    }

    private async Task OpenCommentsModal(YearlyBudget budget)
    {
        activeBudget = budget;
        scrutinyDetails = new();
        showCommentsModal = true;
        isLoadingComments = true;
        newComment = "";

        try
        {
            scrutinyDetails = await scrutinyService.GetScrutinyDetails(budget.Id) ?? new();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error fetching comments: {ex.Message}");
        }
        finally
        {
            isLoadingComments = false;
        }
    }

    private void OpenApproveModal(YearlyBudget budget)
    {
        activeBudget = budget;
        // Pre-fill with requested amount so user knows the baseline
        approveAllotedAmount = budget.RequestedAmount;
        showApproveModal = true;
    }

    private void CloseAllModals()
    {
        showDetailsModal = false;
        showCommentsModal = false;
        showApproveModal = false;
        activeBudget = null;
        expandedEvents.Clear();
        newComment = "";
    }

    // ── Accordion ────────────────────────────────────────────
    private void ToggleEvent(Guid eventId)
    {
        if (expandedEvents.Contains(eventId))
            expandedEvents.Remove(eventId);
        else
            expandedEvents.Add(eventId);
    }

    // ── Add Comment ──────────────────────────────────────────
    private async Task HandleAddComment()
    {
        if (activeBudget == null || string.IsNullOrWhiteSpace(newComment)) return;

        isSendingComment = true;
        try
        {
            var dto = new AddCommentDto
            {
                AdministrationName = userName,
                AdministrationComment = newComment.Trim(),
                AdministrationRole = Role ?? "",
                CommentDate = DateTime.Now,
                YearlyBudgetId = activeBudget.Id
            };

            var result = await scrutinyService.AddComment(Id, dto);
            if (result.Success)
            {
                newComment = "";
                // Refresh comments list
                scrutinyDetails = await scrutinyService.GetScrutinyDetails(activeBudget.Id) ?? new();
            }
            else
            {
                await JS.InvokeVoidAsync("alert", $"Failed to add comment: {result.Error}");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error adding comment: {ex.Message}");
        }
        finally
        {
            isSendingComment = false;
        }
    }

    // ── Delete Comment ────────────────────────────────────────
    private async Task HandleDeleteComment(Guid commentId)
    {
        bool confirm = await JS.InvokeAsync<bool>("confirm", "Are you sure you want to delete this comment?");
        if (!confirm) return;

        try
        {
            var result = await scrutinyService.DeleteComment(commentId);
            if (result.Success)
            {
                // Refresh comments list
                if (activeBudget != null)
                    scrutinyDetails = await scrutinyService.GetScrutinyDetails(activeBudget.Id) ?? new();
            }
            else
            {
                await JS.InvokeVoidAsync("alert", $"Failed to delete comment: {result.Error}");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error deleting comment: {ex.Message}");
        }
    }

    // ── Approve ───────────────────────────────────────────────
    private async Task HandleApprove()
    {
        if (activeBudget == null) return;

        if (approveAllotedAmount <= 0)
        {
            await JS.InvokeVoidAsync("alert", "Allotted amount must be greater than zero.");
            return;
        }

        isActing = true;
        try
        {
            var dto = new ApproveYearlyBudgetDto
            {
                Id = activeBudget.Id,
                AllotedAmount = approveAllotedAmount,
                AllotedDate = DateTime.Today,
                Credits = approveAllotedAmount // Initial credits equal to allotted amount
            };

            var result = await scrutinyService.ApproveYearlyBudget(activeBudget.Id, dto);
            if (result.Success)
            {
                await JS.InvokeVoidAsync("alert", "Yearly budget approved successfully.");
                CloseAllModals();
                await OnInitializedAsync();
            }
            else
            {
                await JS.InvokeVoidAsync("alert", $"Failed to approve: {result.Error}");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error approving: {ex.Message}");
            await JS.InvokeVoidAsync("alert", "An error occurred while approving the budget.");
        }
        finally
        {
            isActing = false;
        }
    }
}
