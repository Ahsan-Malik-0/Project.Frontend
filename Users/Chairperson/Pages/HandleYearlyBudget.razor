@page "/chairperson/yearly-budget"

@layout ChairpersonLayout

@attribute [Authorize(Roles = "chairperson")]

<div class="container-fluid py-4 px-4">

    <!-- Page Header -->
    <div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mb-4">
        <h4 class="fw-bold mb-0">Yearly Budget</h4>

        <div class="d-flex align-items-center gap-2 flex-wrap">
            @if (yearlyBudgets.Count > 0)
            {
                <div class="d-flex align-items-center gap-2">
                    <label class="form-label mb-0 text-muted small fw-semibold">Session:</label>
                    <select class="form-select form-select-sm" style="width: auto;" @onchange="OnSessionChanged">
                        @foreach (var b in yearlyBudgets.OrderByDescending(x => x.Session))
                        {
                            <option value="@b.Id" selected="@(selectedBudget?.Id == b.Id)">
                                @b.Session
                            </option>
                        }
                    </select>
                </div>
            }

            <button class="btn btn-primary btn-sm px-3" @onclick="GoToCreate">
                <i class="bi bi-plus-lg me-1"></i> New Budget
            </button>
        </div>
    </div>

    <!-- Loading -->
    @if (loading)
    {
        <div class="text-center text-muted py-5">
            <div class="spinner-border spinner-border-sm mb-2"></div>
            <p class="mb-0">Loading yearly budgets...</p>
        </div>
    }
    else if (yearlyBudgets.Count == 0)
    {
        <div class="text-center text-muted py-5">
            <i class="bi bi-inbox fs-1 d-block mb-2"></i>
            <p class="mb-0">No yearly budgets found. Create one to get started.</p>
        </div>
    }
    else
    {
        <!-- Budget Summary Cards -->
        <div class="row g-3 mb-4">

            <div class="col-6 col-md-3">
                <div class="card h-100 border shadow-sm">
                    <div class="card-body">
                        <p class="text-muted small text-uppercase fw-semibold mb-1"
                               style="font-size: 0.7rem; letter-spacing: 0.06em;">
                            Requested Amount
                        </p>
                        <h5 class="fw-bold text-primary mb-1">@selectedBudget?.RequestedAmount</h5>
                        <p class="text-muted mb-0" style="font-size: 0.75rem;">
                            @selectedBudget?.RequestedDate.ToString("dd MMM yyyy")
                        </p>
                    </div>
                </div>
            </div>

            <div class="col-6 col-md-3">
                <div class="card h-100 border shadow-sm">
                    <div class="card-body">
                        <p class="text-muted small text-uppercase fw-semibold mb-1"
                               style="font-size: 0.7rem; letter-spacing: 0.06em;">
                            Alloted Amount
                        </p>
                        <h5 class="fw-bold text-success mb-1">
                            @(selectedBudget?.AllotedAmount > 0 ? selectedBudget?.AllotedAmount.ToString("C") : "—")
                        </h5>
                        <p class="text-muted mb-0" style="font-size: 0.75rem;">
                            @(selectedBudget?.AllotedDate != default(DateTime)
                                ? selectedBudget?.AllotedDate.ToString("dd MMM yyyy")
                                : "Not alloted yet")
                        </p>
                    </div>
                </div>
            </div>

            <div class="col-6 col-md-3">
                <div class="card h-100 border shadow-sm">
                    <div class="card-body">
                        <p class="text-muted small text-uppercase fw-semibold mb-1"
                               style="font-size: 0.7rem; letter-spacing: 0.06em;">
                            Credits
                        </p>
                        <h5 class="fw-bold text-warning mb-1">
                            @(selectedBudget?.Credits > 0 ? selectedBudget?.Credits.ToString("C") : "—")
                        </h5>
                    </div>
                </div>
            </div>

            <div class="col-6 col-md-3">
                <div class="card h-100 border shadow-sm">
                    <div class="card-body">
                        <p class="text-muted small text-uppercase fw-semibold mb-1"
                               style="font-size: 0.7rem; letter-spacing: 0.06em;">
                            Total Events
                        </p>
                        <h5 class="fw-bold mb-1">@(selectedBudget?.YearlyEvents?.Count ?? 0)</h5>
                    </div>
                </div>
            </div>

        </div>

        <!-- Events Section Title -->
        <div class="d-flex align-items-center gap-2 mb-3">
            <h5 class="fw-bold mb-0">Events</h5>
            <span class="badge bg-primary bg-opacity-10 text-primary fw-semibold">
                @(selectedBudget?.YearlyEvents?.Count ?? 0) planned
            </span>
        </div>

        @if (selectedBudget?.YearlyEvents == null || !selectedBudget.YearlyEvents.Any())
        {
            <div class="text-center text-muted py-4">
                <i class="bi bi-calendar-x fs-3 d-block mb-2"></i>
                <p class="mb-0 small">No events planned for this session yet.</p>
            </div>
        }
        else
        {
            <!-- Events Accordion -->
            <div class="accordion" id="eventsAccordion">
                @foreach (var ev in selectedBudget.YearlyEvents)
                {
                    bool isOpen = expandedEvents.Contains(ev.Id);

                    <div class="accordion-item border mb-2 rounded shadow-sm overflow-hidden">

                        <!-- Event Header -->
                        <h2 class="accordion-header">
                            <button class="accordion-button @(isOpen ? "" : "collapsed") fw-semibold" type="button"
                                    @onclick="() => ToggleEvent(ev.Id)">

                                <div class="d-flex align-items-center justify-content-between w-100 flex-wrap gap-2 pe-2">

                                    <span>@ev.Name</span>

                                    <div class="d-flex align-items-center gap-3 text-muted small fw-normal">
                                        <span>
                                            <i class="bi bi-calendar3 me-1"></i>@ev.EstimateMonth
                                        </span>
                                        @if (ev.EstimateAmount.HasValue)
                                        {
                                            <span class="text-success fw-semibold">
                                                @ev.EstimateAmount.Value.ToString("C")
                                            </span>
                                        }
                                        <span class="badge bg-secondary bg-opacity-10 text-secondary fw-normal">
                                            @(ev.YearlyEventRequirements?.Count ?? 0) req(s)
                                        </span>
                                    </div>

                                </div>

                            </button>
                        </h2>

                        <!-- Requirements Table -->
                        @if (isOpen)
                        {
                            <div class="accordion-collapse show">
                                <div class="accordion-body p-0">
                                    @if (ev.YearlyEventRequirements == null || !ev.YearlyEventRequirements.Any())
                                    {
                                        <p class="text-center text-muted py-3 mb-0 small">
                                            No requirements added for this event.
                                        </p>
                                    }
                                    else
                                    {
                                        <div class="table-responsive">
                                            <table class="table table-hover table-sm align-middle mb-0">
                                                <thead class="table-light">
                                                    <tr>
                                                        <th class="text-muted small ps-3" style="width: 2.5rem;">#</th>
                                                        <th class="text-muted small">Requirement</th>
                                                        <th class="text-muted small">Estimate Price</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    @{
                                                        int reqIndex = 1;
                                                    }
                                                    @foreach (var req in ev.YearlyEventRequirements)
                                                    {
                                                        <tr>
                                                            <td class="text-muted ps-3">@reqIndex</td>
                                                            <td>@req.Name</td>
                                                            <td class="text-success fw-semibold">
                                                                @(req.EstimatePrice.HasValue
                                                                    ? req.EstimatePrice.Value.ToString("C")
                                                                    : "—")
                                                            </td>
                                                        </tr>
                                                        reqIndex++;
                                                    }
                                                </tbody>
                                            </table>
                                        </div>
                                    }
                                </div>
                            </div>
                        }

                    </div>
                }
            </div>
        }
    }

</div>


@inject ChairpersonServices chairpersonServices
@inject ClaimServices claimServices
@inject NavigationManager Navigation

@code {
    bool loading = true;
    private List<YearlyBudgetResponseDto> yearlyBudgets = new();
    private YearlyBudgetResponseDto? selectedBudget;
    private HashSet<Guid> expandedEvents = new();

    protected override async Task OnInitializedAsync()
    {
        loading = true;
        try
        {
            var claims = await claimServices.GetClaims();
            yearlyBudgets = await chairpersonServices.GetAllYearlyBudgets(Guid.Parse(claims.Id));

            // Show the most recent session by default
            selectedBudget = yearlyBudgets
                .OrderByDescending(b => b.Session)
                .FirstOrDefault();
        }
        catch (Exception ex)
        {
            Console.Error.WriteLine($"Error fetching yearly budgets: {ex.Message}");
        }
        finally
        {
            loading = false;
        }
    }

    private void OnSessionChanged(ChangeEventArgs e)
    {
        if (Guid.TryParse(e.Value?.ToString(), out var id))
        {
            selectedBudget = yearlyBudgets.FirstOrDefault(b => b.Id == id);
            expandedEvents.Clear();
        }
    }

    private void ToggleEvent(Guid eventId)
    {
        if (expandedEvents.Contains(eventId))
            expandedEvents.Remove(eventId);
        else
            expandedEvents.Add(eventId);
    }

    private void GoToCreate()
    {
        Navigation.NavigateTo("/chairperson/yearly-budget/create");
    }
}
