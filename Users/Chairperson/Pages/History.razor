@page "/chairperson/history"
@layout ChairpersonLayout
@attribute [Authorize(Roles = "chairperson")]

<div class="container-fluid px-4 py-4">

    <h4 class="fw-bold mb-4">Requisition History</h4>

    @if (isLoading)
    {
        <div class="text-center text-muted py-5">
            <div class="spinner-border spinner-border-sm mb-2"></div>
            <p class="mb-0">Loading history...</p>
        </div>
    }
    else if (history == null || history.Count == 0)
    {
        <div class="text-center text-muted py-5">
            <i class="bi bi-clock-history fs-1 d-block mb-2"></i>
            <p class="mb-0">No completed requisitions found.</p>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var item in history)
            {
                <div class="col-12 col-md-6 col-xl-4">
                    <div class="card border-0 shadow-sm h-100">

                        <!-- Header -->
                        <div class="card-header bg-white border-bottom py-3">
                            <h6 class="fw-bold mb-0">@item.EventName</h6>
                        </div>

                        <!-- Stats Body -->
                        <div class="card-body">

                            <div class="row g-2 mb-3">
                                <div class="col-6">
                                    <div class="bg-light rounded p-2 text-center">
                                        <div class="text-muted small" style="font-size:0.7rem;text-transform:uppercase;letter-spacing:0.05em;">Requested</div>
                                        <div class="fw-bold text-primary small">Rs @item.RequestedAmount.ToString("N0")</div>
                                    </div>
                                </div>
                                <div class="col-6">
                                    <div class="bg-light rounded p-2 text-center">
                                        <div class="text-muted small" style="font-size:0.7rem;text-transform:uppercase;letter-spacing:0.05em;">Allocated</div>
                                        <div class="fw-bold text-success small">Rs @item.AllocatedAmount.ToString("N0")</div>
                                    </div>
                                </div>
                                <div class="col-6">
                                    <div class="bg-light rounded p-2 text-center">
                                        <div class="text-muted small" style="font-size:0.7rem;text-transform:uppercase;letter-spacing:0.05em;">BIIT Share</div>
                                        <div class="fw-bold text-warning small">Rs @item.BiitContribution.ToString("N0")</div>
                                    </div>
                                </div>
                                <div class="col-6">
                                    <div class="bg-light rounded p-2 text-center">
                                        <div class="text-muted small" style="font-size:0.7rem;text-transform:uppercase;letter-spacing:0.05em;">Allocated On</div>
                                        <div class="fw-bold small">@item.AllocatedDate.ToString("dd MMM yyyy")</div>
                                    </div>
                                </div>
                            </div>

                            <p class="mb-0 text-muted small">
                                <i class="bi bi-send me-1"></i>
                                Requested on @item.RequestedDate.ToString("dd MMM yyyy")
                            </p>
                        </div>

                        <!-- Footer -->
                        <div class="card-footer bg-white border-top d-flex gap-2 py-3">
                            <button class="btn btn-outline-primary btn-sm flex-fill"
                                    @onclick="() => OpenViewModal(item.RequisitionId)">
                                <i class="bi bi-eye me-1"></i> View Requisition
                            </button>
                            <button class="btn btn-outline-secondary btn-sm flex-fill"
                                    @onclick="() => OpenAuditModal(item)">
                                <i class="bi bi-journal-text me-1"></i> Audit
                            </button>
                        </div>

                    </div>
                </div>
            }
        </div>
    }

</div>


<!-- ===== MODAL: View Requisition ===== -->
@if (showViewModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background:rgba(0,0,0,0.5)">
        <div class="modal-dialog modal-xl modal-dialog-centered modal-dialog-scrollable">
            <div class="modal-content border-0 shadow">
                <div class="modal-header border-bottom">
                    <h6 class="modal-title fw-bold">Requisition Details</h6>
                    <button class="btn-close" @onclick="CloseAllModals"></button>
                </div>
                <div class="modal-body p-5">

                    @if (isLoadingDetails)
                    {
                        <div class="text-center py-4">
                            <div class="spinner-border spinner-border-sm mb-2"></div>
                            <p class="mb-0 text-muted">Loading details...</p>
                        </div>
                    }
                    else if (selectedRequisition == null)
                    {
                        <p class="text-center text-muted">No details available.</p>
                    }
                    else
                    {
                        <!-- Header -->
                        <div class="d-flex align-items-center gap-4 border-bottom pb-3 mb-4">
                            <img src="/images/biit_logo.png" alt="BIIT Logo" style="max-width:80px;" />
                            <div>
                                <h4 class="fw-bold mb-0">Barani Institute Of Information Technology</h4>
                                <small class="text-muted">Official Event Requisition Application</small>
                            </div>
                        </div>

                        <!-- Subject + Dates -->
                        <div class="mb-4">
                            <p class="mb-1"><strong>Subject:</strong> @selectedRequisition.Subject</p>
                            <p class="mb-1"><strong>Requested Date:</strong> @selectedRequisition.RequestedDate.ToString("dd MMM yyyy")</p>
                            <p class="mb-0"><strong>Event Date:</strong> @selectedRequisition.EventDate.ToString("dd MMM yyyy")</p>
                        </div>

                        <!-- Body -->
                        <div class="mb-4">
                            <p>Respected Sir,</p>
                            <p style="white-space:pre-line;">@selectedRequisition.Body</p>
                        </div>

                        <!-- Requirements -->
                        @if (selectedRequisition.EventRequirements != null && selectedRequisition.EventRequirements.Any())
                        {
                            <strong>@selectedRequisition.SocietyName Society need the following:</strong>
                            <div class="table-responsive mb-4 mt-2">
                                <table class="table table-bordered align-middle">
                                    <thead class="table-light text-center">
                                        <tr>
                                            <th>Type</th>
                                            <th>Name</th>
                                            <th>Qty</th>
                                            <th>Unit Price</th>
                                            <th>Total</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var req in selectedRequisition.EventRequirements)
                                        {
                                            <tr>
                                                <td>@req.Type</td>
                                                <td>@req.Name</td>
                                                <td class="text-center">@req.Quantity</td>
                                                <td class="text-end">@req.Price.ToString("N2")</td>
                                                <td class="text-end fw-semibold">@((req.Quantity * req.Price).ToString("N2"))</td>
                                            </tr>
                                        }
                                    </tbody>
                                    <tfoot class="table-light">
                                        <tr>
                                            <td colspan="4" class="text-end fw-bold">Total Requested Amount:</td>
                                            <td class="text-end fw-bold text-primary">
                                                @selectedRequisition.EventRequirements.Sum(r => r.Quantity * r.Price).ToString("N2")
                                            </td>
                                        </tr>
                                    </tfoot>
                                </table>
                            </div>
                        }
                        else
                        {
                            <p class="text-center text-muted">No requirements added for this event.</p>
                        }

                        <!-- Signature -->
                        <div class="mt-5 pt-4 border-top">
                            <p class="mb-1 fw-semibold">@selectedRequisition.ChairpersonName</p>
                            <p class="mb-4 text-muted">Chairperson (@selectedRequisition.SocietyName)</p>
                            <p class="mb-1 fw-semibold">Mr. Shahid Rashid</p>
                            <p class="text-muted">Assistant Director Student Affairs</p>
                        </div>
                    }

                </div>
                <div class="modal-footer border-top">
                    <button class="btn btn-secondary btn-sm" @onclick="CloseAllModals">Close</button>
                </div>
            </div>
        </div>
    </div>
}


<!-- ===== MODAL: Audit ===== -->
@if (showAuditModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background:rgba(0,0,0,0.5)">
        <div class="modal-dialog modal-lg modal-dialog-centered modal-dialog-scrollable">
            <div class="modal-content border-0 shadow">
                <div class="modal-header border-bottom">
                    <h6 class="modal-title fw-bold">
                        <i class="bi bi-journal-text me-2"></i>Event Audit — @activeEventName
                    </h6>
                    <button class="btn-close" @onclick="CloseAllModals"></button>
                </div>

                <div class="modal-body">

                    @if (isLoadingAudit)
                    {
                        <div class="text-center py-4">
                            <div class="spinner-border spinner-border-sm mb-2"></div>
                            <p class="mb-0 text-muted">Loading audit...</p>
                        </div>
                    }
                    @* else if (activeAudit == null) *@
                    else if (activeAudit == null)
                    {
                        <!-- No audit exists -->
                        <div class="text-center py-5">
                            <i class="bi bi-journal-x fs-1 text-muted d-block mb-3"></i>
                            <p class="text-muted mb-0">Audit does not exist for this event.</p>
                            <p class="text-muted small">Upload an audit report to track how the budget was spent.</p>
                        </div>
                    }
                    else
                    {
                        <!-- Status Badge — prominent at top -->
                        <div class="text-center mb-4">
                            <span class="badge fs-6 px-4 py-2 @GetStatusBadgeClass(activeAudit.Status)">
                                <i class="bi @GetStatusIcon(activeAudit.Status) me-2"></i>
                                @activeAudit.Status
                            </span>

                            @if (activeAudit.Status == "take")
                            {
                                <div class="mt-3">
                                    <p class="text-danger small mb-2">
                                        <i class="bi bi-exclamation-circle me-1"></i>
                                        You need to collect <strong>Rs @((activeAudit.SpendAmount - activeAudit.FundProvided).ToString("N0"))</strong> from the account office.
                                    </p>
                                    <button class="btn btn-success btn-sm px-4"
                                            disabled="@isActing"
                                            @onclick="VerifyTakeAmount">
                                        @if (isActing)
                                        {
                                            <span class="spinner-border spinner-border-sm me-1"></span>
                                        }
                                        <i class="bi bi-check-circle me-1"></i> Verify — Amount Taken
                                    </button>
                                </div>
                            }
                            else if (activeAudit.Status == "give")
                            {
                                <div class="alert alert-warning mt-3 py-2 small text-start">
                                    <i class="bi bi-exclamation-triangle me-1"></i>
                                    You have <strong>Rs @((activeAudit.FundProvided - activeAudit.SpendAmount).ToString("N0"))</strong> remaining.
                                    Please return the extra amount to the account office as soon as possible.
                                </div>
                            }
                        </div>

                        <hr />

                        <!-- Audit Stats -->
                        <div class="row g-3 mb-4">
                            <div class="col-6 col-md-3">
                                <div class="bg-light rounded p-3 text-center">
                                    <div class="text-muted small mb-1" style="font-size:0.7rem;text-transform:uppercase;">Fund Provided</div>
                                    <div class="fw-bold text-primary">Rs @activeAudit.FundProvided.ToString("N0")</div>
                                </div>
                            </div>
                            <div class="col-6 col-md-3">
                                <div class="bg-light rounded p-3 text-center">
                                    <div class="text-muted small mb-1" style="font-size:0.7rem;text-transform:uppercase;">Amount Spent</div>
                                    <div class="fw-bold text-danger">Rs @activeAudit.SpendAmount.ToString("N0")</div>
                                </div>
                            </div>
                            <div class="col-6 col-md-3">
                                <div class="bg-light rounded p-3 text-center">
                                    <div class="text-muted small mb-1" style="font-size:0.7rem;text-transform:uppercase;">Revenue</div>
                                    <div class="fw-bold text-success">Rs @activeAudit.RevenueGenerated.ToString("N0")</div>
                                </div>
                            </div>
                            <div class="col-6 col-md-3">
                                <div class="bg-light rounded p-3 text-center">
                                    <div class="text-muted small mb-1" style="font-size:0.7rem;text-transform:uppercase;">Remaining</div>
                                    <div class="fw-bold">Rs @activeAudit.RemainingAmount.ToString("N0")</div>
                                </div>
                            </div>
                        </div>

                        <!-- Spends Table -->
                        @if (activeAudit.Spends != null && activeAudit.Spends.Any())
                        {
                            <h6 class="fw-semibold mb-3">Spend Details</h6>
                            <div class="table-responsive">
                                <table class="table table-bordered table-sm align-middle">
                                    <thead class="table-light">
                                        <tr>
                                            <th class="small">#</th>
                                            <th class="small">Vendor</th>
                                            <th class="small">Description</th>
                                            <th class="small text-end">Amount</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @{ int i = 1; }
                                        @foreach (var spend in activeAudit.Spends)
                                        {
                                            <tr>
                                                <td class="text-muted">@i</td>
                                                <td>@spend.Vender</td>
                                                <td class="text-muted small">@(spend.Description ?? "—")</td>
                                                <td class="text-end fw-semibold">Rs @spend.Amount.ToString("N0")</td>
                                            </tr>
                                            i++;
                                        }
                                    </tbody>
                                    <tfoot class="table-light">
                                        <tr>
                                            <td colspan="3" class="text-end fw-bold">Total Spent:</td>
                                            <td class="text-end fw-bold text-danger">
                                                Rs @activeAudit.Spends.Sum(s => s.Amount).ToString("N0")
                                            </td>
                                        </tr>
                                    </tfoot>
                                </table>
                            </div>
                        }
                    }

                </div>

                <div class="modal-footer border-top">
                    @* @if (activeAudit == null && !isLoadingAudit) *@
                    @if (activeAudit == null && !isLoadingAudit)
                    {
                        <!-- No audit — show create button -->
                        <a class="btn btn-primary btn-sm px-4"
                           href="/chairperson/handle-audit?eventId=@activeEventId&AllotedAmount=@activeAllotedAmount">
                            <i class="bi bi-plus-circle me-1"></i> Create Audit
                        </a>
                    }
                    else if (activeAudit != null)
                    {
                        bool isClear = activeAudit.Status == "clear";

                        <button class="btn btn-outline-danger btn-sm"
                                disabled="@(isClear || isActing)"
                                @onclick="DeleteAudit">
                            <i class="bi bi-trash me-1"></i> Delete
                        </button>

                        <a class="btn btn-outline-warning btn-sm @(isClear ? "disabled" : "")"
                           href="/chairperson/handle-audit?eventId=@activeEventId&auditId=@activeAudit.Id">
                            <i class="bi bi-pencil me-1"></i> Update
                        </a>
                    }

                    <button class="btn btn-secondary btn-sm" @onclick="CloseAllModals">Close</button>
                </div>

            </div>
        </div>
    </div>
}


@inject ChairpersonServices chairpersonServices
@inject ClaimServices claimServices
@inject IJSRuntime JS

@code {
    private bool isLoading = false;
    private bool isLoadingDetails = false;
    private bool isLoadingAudit = false;
    private bool isActing = false;

    private List<EventRequisitionHistoryDto> history = new();
    private EventRequisitionDetailsDto? selectedRequisition;
    private EventAudit? activeAudit;

    // ── Modal flags ──────────────────────────────────────────
    private bool showViewModal = false;
    private bool showAuditModal = false;

    // ── Active selection ─────────────────────────────────────
    private Guid activeRequisitionId;
    private Guid activeEventId;
    private string activeAllotedAmount = "";
    private string activeEventName = "";

    // ── Init ─────────────────────────────────────────────────
    protected override async Task OnInitializedAsync()
    {
        isLoading = true;
        try
        {
            var claims = await claimServices.GetClaims();
            history = await chairpersonServices.GetRequisitionHistory(Guid.Parse(claims.Id)) ?? new();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading history: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    // ── Modal Openers ────────────────────────────────────────
    private async Task OpenViewModal(Guid requisitionId)
    {
        selectedRequisition = null;
        showViewModal = true;
        isLoadingDetails = true;

        try
        {
            selectedRequisition = await chairpersonServices.GetRequisitionDetails(requisitionId);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading requisition: {ex.Message}");
        }
        finally
        {
            isLoadingDetails = false;
        }
    }

    private async Task OpenAuditModal(EventRequisitionHistoryDto item)
    {
        activeRequisitionId = item.RequisitionId;
        activeEventId = item.EventId;
        activeAllotedAmount = (item.AllocatedAmount + item.BiitContribution).ToString("F2");
        activeEventName = item.EventName;
        activeAudit = null;
        showAuditModal = true;
        isLoadingAudit = true;

        try
        {
            activeAudit = await chairpersonServices.GetEventAudit(item.EventId);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading audit: {ex.Message}");
        }
        finally
        {
            isLoadingAudit = false;
        }
    }

    private void CloseAllModals()
    {
        showViewModal = false;
        showAuditModal = false;
        selectedRequisition = null;
        activeAudit = null;
    }

    // ── Audit Actions ────────────────────────────────────────
    private async Task VerifyTakeAmount()
    {
        if (activeAudit == null) return;

        bool confirm = await JS.InvokeAsync<bool>("confirm", "Confirm that you have received the amount from the account office?");
        if (!confirm) return;

        isActing = true;
        try
        {
            var response = await chairpersonServices.VerifyTakeAmount(activeAudit.Id);
            @* var response = true; // Simulate success response for now *@
            if (response.Success)
            {
                activeAudit.Status = "clear";
                await JS.InvokeVoidAsync("alert", "Status updated to Clear.");
            }
            else
            {
                await JS.InvokeVoidAsync("alert", $"Failed: {response?.Error}");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error verifying: {ex.Message}");
        }
        finally
        {
            isActing = false;
        }
    }

    private async Task DeleteAudit()
    {
        if (activeAudit == null) return;

        bool confirm = await JS.InvokeAsync<bool>("confirm", "Are you sure you want to delete this audit?");
        if (!confirm) return;

        isActing = true;
        try
        {
            var response = await chairpersonServices.DeleteEventAudit(activeAudit.Id);
            if (response?.Success == true)
            {
                activeAudit = null;
                await JS.InvokeVoidAsync("alert", "Audit deleted successfully.");
            }
            else
            {
                await JS.InvokeVoidAsync("alert", $"Failed to delete: {response?.Error}");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error deleting audit: {ex.Message}");
        }
        finally
        {
            isActing = false;
        }
    }

    // ── Helpers ──────────────────────────────────────────────
    private string GetStatusBadgeClass(string? status) => status switch
    {
        "clear" => "bg-success",
        "take"  => "bg-danger",
        "give"  => "bg-warning text-dark",
        _       => "bg-secondary"
    };

    private string GetStatusIcon(string? status) => status switch
    {
        "clear" => "bi-check-circle-fill",
        "take"  => "bi-arrow-down-circle-fill",
        "give"  => "bi-arrow-up-circle-fill",
        _       => "bi-question-circle"
    };
}
