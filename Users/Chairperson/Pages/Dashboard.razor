@page "/chairperson"

@layout ChairpersonLayout

@attribute [Authorize(Roles = "chairperson")]

@if (loading)
{
    <div class="text-center py-5">
        <div class="spinner-border text-primary"></div>
        <p class="mt-3 text-muted">Loading Pending Requisitions...</p>
    </div>
}
else if (pendingEventRequisitions.Count == 0)
{
    <div class="text-center py-5">
        <p class="text-muted fs-5">No pending requisitions available</p>
    </div>
}
else
{
    <h4 class="fw-bold mb-3">Pending Requisitions:</h4>
    <div class="row g-4">
        @foreach (var pr in pendingEventRequisitions)
        {
            bool isRejected = pr.Status.Contains("Reject", StringComparison.OrdinalIgnoreCase);
            bool hasReviewMessage = !string.IsNullOrWhiteSpace(pr.ReviewMessage);

            <div class="col-lg-4 col-md-6">
                <div class="card h-100 shadow-sm border">

                    <!-- Header -->
                    <div class="card-header">
                        <div class="d-flex justify-content-between align-items-center">
                            <h6 class="fw-bold mb-0">@pr.EventName</h6>
                            <span class="badge @GetStatusBadgeClass(pr.Status)">
                                @pr.Status
                            </span>
                        </div>
                    </div>

                    <div class="card-body d-flex flex-column">
                        <p class="text-muted small mb-3">
                            <strong>Event Date:</strong> @pr.EventDate.ToString("dd MMM yyyy")
                        </p>

                        <!-- Action Buttons -->
                        <div class="mt-auto">

                            <!-- Top row: Track + View -->
                            <div class="d-flex gap-2 mb-2">
                                <button class="btn btn-sm btn-outline-info w-50"
                                        @onclick="() => OpenStatusModal(pr.Status)">
                                    <i class="bi bi-bar-chart-steps me-1"></i> Track Status
                                </button>

                                <button class="btn btn-sm btn-primary w-50"
                                        @onclick="() => OpenViewModal(pr.Id)">
                                    <i class="bi bi-eye me-1"></i> View
                                </button>
                            </div>

                            <!-- Bottom row: Delete + Edit + Mail -->
                            <div class="d-flex gap-2">
                                <button class="btn btn-sm btn-outline-danger w-100"
                                        @onclick="() => DeleteRequisition(pr.Id)">
                                    <i class="bi bi-trash me-1"></i> Delete
                                </button>

                                @if (isRejected)
                                {
                                    <a class="btn btn-sm btn-outline-warning w-100"
                                    href="/chairperson/update-requisition?id=@pr.Id">
                                        <i class="bi bi-pencil me-1"></i> Edit
                                    </a>

                                    @if (hasReviewMessage)
                                    {
                                        <button class="btn btn-sm btn-outline-secondary flex-shrink-0"
                                                title="View Rejection Message"
                                                @onclick="() => OpenReviewMessageModal(pr.ReviewMessage!)">
                                            <i class="bi bi-envelope-fill text-danger"></i>
                                        </button>
                                    }
                                }
                            </div>

                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}


<!-- ===== MODAL: Status Tracker ===== -->
@if (showStatusModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background:rgba(0,0,0,0.5)">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow">
                <div class="modal-header border-bottom">
                    <h6 class="modal-title fw-bold">
                        <i class="bi bi-bar-chart-steps me-2"></i>Requisition Status
                    </h6>
                    <button class="btn-close" @onclick="CloseAllModals"></button>
                </div>
                <div class="modal-body py-4 px-4">
                    <ul class="list-unstyled mb-0">
                        @foreach (var step in GetStatusSteps(activeStatus))
                        {
                            <li class="d-flex align-items-start gap-3 mb-4">
                                <!-- Icon circle -->
                                <div class="rounded-circle d-flex align-items-center justify-content-center flex-shrink-0"
                                     style="width:36px;height:36px;background-color:@step.CircleColor">
                                    <i class="bi @step.Icon" style="color:white;font-size:0.85rem;"></i>
                                </div>
                                <!-- Label -->
                                <div>
                                    <p class="mb-0 fw-semibold @step.TextClass">@step.Label</p>
                                    @if (!string.IsNullOrEmpty(step.SubLabel))
                                    {
                                        <small class="text-muted">@step.SubLabel</small>
                                    }
                                </div>
                            </li>
                        }
                    </ul>
                </div>
                <div class="modal-footer border-top">
                    <button class="btn btn-secondary btn-sm" @onclick="CloseAllModals">Close</button>
                </div>
            </div>
        </div>
    </div>
}


<!-- ===== MODAL: Rejection Message ===== -->
@if (showReviewModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background:rgba(0,0,0,0.5)">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow">
                <div class="modal-header border-bottom">
                    <h6 class="modal-title fw-bold">
                        <i class="bi bi-envelope-fill text-danger me-2"></i>Rejection Message
                    </h6>
                    <button class="btn-close" @onclick="CloseAllModals"></button>
                </div>
                <div class="modal-body">
                    <div class="alert alert-danger py-2 mb-0 small">
                        <i class="bi bi-exclamation-circle me-1"></i>
                        Your requisition was rejected with the following message:
                    </div>
                    <p class="mt-3 mb-0">@activeReviewMessage</p>
                </div>
                <div class="modal-footer border-top">
                    <button class="btn btn-secondary btn-sm" @onclick="CloseAllModals">Close</button>
                </div>
            </div>
        </div>
    </div>
}


<!-- ===== MODAL: View Requisition ===== -->
@if (showViewModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background:rgba(0,0,0,0.5)">
        <div class="modal-dialog modal-xl modal-dialog-centered modal-dialog-scrollable">
            <div class="modal-content border-0 shadow">
                <div class="modal-header border-bottom">
                    <h6 class="modal-title fw-bold">Requisition Details</h6>
                    <button class="btn-close" @onclick="CloseAllModals"></button>
                </div>
                <div class="modal-body p-5">

                    @if (selectedRequisition == null)
                    {
                        <div class="text-center py-5">
                            <div class="spinner-border text-primary"></div>
                            <p class="mt-3 text-muted">Loading requisition details...</p>
                        </div>
                    }
                    else
                    {
                        <!-- Header -->
                        <div class="d-flex align-items-center gap-4 border-bottom pb-3 mb-4">
                            <img src="/images/biit_logo.png" alt="BIIT Logo" style="max-width:80px;" />
                            <div>
                                <h4 class="fw-bold mb-0">Barani Institute Of Information Technology</h4>
                                <small class="text-muted">Official Event Requisition Application</small>
                            </div>
                        </div>

                        <!-- Subject + Dates -->
                        <div class="mb-4">
                            <p class="mb-1"><strong>Subject:</strong> @selectedRequisition.Subject</p>
                            <p class="mb-1"><strong>Requested Date:</strong> @selectedRequisition.RequestedDate.ToString("dd MMM yyyy")</p>
                            <p class="mb-0"><strong>Event Date:</strong> @selectedRequisition.EventDate.ToString("dd MMM yyyy")</p>
                        </div>

                        <!-- Body -->
                        <div class="mb-4">
                            <p>Respected Sir,</p>
                            <p style="white-space:pre-line;">@selectedRequisition.Body</p>
                        </div>

                        <!-- Requirements -->
                        @if (selectedRequisition.EventRequirements != null && selectedRequisition.EventRequirements.Any())
                        {
                            <strong>@selectedRequisition.SocietyName Society need the following:</strong>
                            <div class="table-responsive mb-4 mt-2">
                                <table class="table table-bordered align-middle">
                                    <thead class="table-light text-center">
                                        <tr>
                                            <th>Type</th>
                                            <th>Name</th>
                                            <th>Qty</th>
                                            <th>Unit Price</th>
                                            <th>Total</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var req in selectedRequisition.EventRequirements)
                                        {
                                            <tr>
                                                <td>@req.Type</td>
                                                <td>@req.Name</td>
                                                <td class="text-center">@req.Quantity</td>
                                                <td class="text-end">@req.Price.ToString("N2")</td>
                                                <td class="text-end fw-semibold">@((req.Quantity * req.Price).ToString("N2"))</td>
                                            </tr>
                                        }
                                    </tbody>
                                    <tfoot class="table-light">
                                        <tr>
                                            <td colspan="4" class="text-end fw-bold">Total Requested Amount:</td>
                                            <td class="text-end fw-bold text-primary">
                                                @TotalRequestedAmount.ToString("N2")
                                            </td>
                                        </tr>
                                    </tfoot>
                                </table>
                            </div>
                        }
                        else
                        {
                            <p class="text-center text-muted">No requirements added for this event.</p>
                        }

                        <!-- Signature -->
                        <div class="mt-5 pt-4 border-top">
                            <p class="mb-1 fw-semibold">@selectedRequisition.ChairpersonName</p>
                            <p class="mb-4 text-muted">Chairperson (@selectedRequisition.SocietyName)</p>
                            <p class="mb-1 fw-semibold">Mr. Shahid Rashid</p>
                            <p class="text-muted">Assistant Director Student Affairs</p>
                        </div>
                    }

                </div>
                <div class="modal-footer border-top">
                    <button class="btn btn-secondary btn-sm" @onclick="CloseAllModals">Close</button>
                </div>
            </div>
        </div>
    </div>
}


@inject ClaimServices claimServices
@inject ChairpersonServices chairpersonServices
@inject IJSRuntime JS
@inject NavigationManager nav

@code {
    private bool loading = false;
    private Guid Id;

    private List<PendingEventRequisitionDto> pendingEventRequisitions = new();
    private EventRequisitionDetailsDto? selectedRequisition = null;
    private decimal TotalRequestedAmount =>
        selectedRequisition?.EventRequirements.Sum(r => r.Price * r.Quantity) ?? 0;

    // ── Modal state ──────────────────────────────────────────
    private bool showStatusModal = false;
    private bool showReviewModal = false;
    private bool showViewModal = false;

    private string activeStatus = string.Empty;
    private string activeReviewMessage = string.Empty;

    // ── Init ─────────────────────────────────────────────────
    protected override async Task OnInitializedAsync()
    {
        loading = true;
        try
        {
            var claims = await claimServices.GetClaims();
            Id = Guid.Parse(claims.Id);
            pendingEventRequisitions = await chairpersonServices.GetPendingRequisitions(Id);
        }
        catch
        {
            await JS.InvokeVoidAsync("alert", "Something went wrong.");
        }
        finally
        {
            loading = false;
        }
    }

    // ── Modal Openers ────────────────────────────────────────
    private void OpenStatusModal(string status)
    {
        activeStatus = status;
        showStatusModal = true;
    }

    private void OpenReviewMessageModal(string message)
    {
        activeReviewMessage = message;
        showReviewModal = true;
    }

    private async Task OpenViewModal(Guid requisitionId)
    {
        selectedRequisition = null;
        showViewModal = true;
        try
        {
            selectedRequisition = await chairpersonServices.GetRequisitionDetails(requisitionId);
        }
        catch
        {
            await JS.InvokeVoidAsync("alert", "Failed to load requisition details.");
        }
    }

    private void CloseAllModals()
    {
        showStatusModal = false;
        showReviewModal = false;
        showViewModal = false;
        selectedRequisition = null;
    }

    // ── Delete ───────────────────────────────────────────────
    private async Task DeleteRequisition(Guid id)
    {
        var confirm = await JS.InvokeAsync<bool>("confirm", "Are you sure you want to delete this requisition?");
        if (!confirm) return;

        var response = await chairpersonServices.DeleteRequisition(id);
        if (response.Success)
        {
            await JS.InvokeVoidAsync("alert", "Requisition deleted successfully.");
            await OnInitializedAsync();
        }
        else
        {
            await JS.InvokeVoidAsync("alert", $"Failed to delete: {response.Error}");
        }
    }

    // ── Helpers ──────────────────────────────────────────────
    private string GetStatusBadgeClass(string status) => status switch
    {
        var s when s.Contains("Reject", StringComparison.OrdinalIgnoreCase) => "bg-danger",
        var s when s.Contains("Approved", StringComparison.OrdinalIgnoreCase) => "bg-success",
        var s when s.Contains("Released", StringComparison.OrdinalIgnoreCase) => "bg-primary",
        _ => "bg-warning text-dark"
    };

    // ── Status Tracker Steps ─────────────────────────────────
    private record StatusStep(string Label, string SubLabel, string CircleColor, string Icon, string TextClass);

    private List<StatusStep> GetStatusSteps(string currentStatus)
    {
        bool saApproved   = currentStatus == "Approved By Student Affairs";
        bool saRejected   = currentStatus == "Reject By Student Affairs";
        bool adminApproved = currentStatus == "Approved By Admin";
        bool adminRejected = currentStatus == "Reject By Admin";
        bool released      = currentStatus == "Budget Released By Finance";

        // Step 1 — always highlighted (Pending = started)
        var step1 = new StatusStep(
            "Pending",
            "Requisition submitted and awaiting review.",
            "#ffc107",
            "bi-hourglass-split",
            "text-warning"
        );

        // Step 2 — Student Affairs
        StatusStep step2;
        if (saRejected)
            step2 = new StatusStep("Reject By Student Affairs", "Rejected at this stage.", "#dc3545", "bi-x-lg", "text-danger");
        else if (saApproved || adminApproved || adminRejected || released)
            step2 = new StatusStep("Approved By Student Affairs", "Approved and forwarded to Admin.", "#198754", "bi-check-lg", "text-success");
        else
            step2 = new StatusStep("Student Affairs Review", "Awaiting review by Student Affairs.", "#ced4da", "bi-clock", "text-muted");

        // Step 3 — Admin
        StatusStep step3;
        if (adminRejected)
            step3 = new StatusStep("Reject By Admin", "Rejected by Admin.", "#dc3545", "bi-x-lg", "text-danger");
        else if (adminApproved || released)
            step3 = new StatusStep("Approved By Admin", "Approved by Admin.", "#198754", "bi-check-lg", "text-success");
        else
            step3 = new StatusStep("Admin Review", "Awaiting Admin approval.", "#ced4da", "bi-clock", "text-muted");

        // Step 4 — Finance
        StatusStep step4;
        if (released)
            step4 = new StatusStep("Budget Released By Finance", "Budget has been released.", "#0d6efd", "bi-cash-stack", "text-primary");
        else
            step4 = new StatusStep("Finance Release", "Awaiting budget release by Finance.", "#ced4da", "bi-cash-stack", "text-muted");

        return new List<StatusStep> { step1, step2, step3, step4 };
    }
}
