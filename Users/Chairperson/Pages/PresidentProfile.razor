@page "/chairperson/president-profile"
@layout ChairpersonLayout
@attribute [Authorize(Roles = "chairperson")]

<h4 class="fw-bold mb-0">President Profile:</h4>

@if (loading)
{
    <div class="text-center text-muted">
        <div class="spinner-border spinner-border-sm"></div>
        <p class="mt-2">Loading profile...</p>
    </div>
}
else if (presidentProfile == null)
{
    <p class="text-center text-muted">Profile not found</p>
}
else
{
    <div class="d-flex justify-content-center">
        <div class="row col-12 col-md-10 col-lg-6 mx-0">
            <div class="card shadow border-1">
                <div class="card-body">

                    @if (error.Length > 0)
                    {
                        <div class="alert alert-danger alert-dismissible fade show" role="alert">
                            <strong>@error</strong>
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    }

                    <EditForm Model="editProfile" OnValidSubmit="HandleUpdate">
                        <DataAnnotationsValidator />

                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label fw-semibold">Name</label>
                                <InputText class="form-control"
                                           @bind-Value="editProfile.Name"
                                           disabled="@(!isEditMode)" />
                                @if (isEditMode)
                                {
                                    <ValidationMessage For="@(() => editProfile.Name)" class="text-danger small" />
                                }
                            </div>

                            <div class="col-md-6">
                                <label class="form-label fw-semibold">Username</label>
                                <InputText class="form-control"
                                           @bind-Value="editProfile.Username"
                                           disabled="@(!isEditMode)" />
                                @if (isEditMode)
                                {
                                    <ValidationMessage For="@(() => editProfile.Username)" class="text-danger small" />
                                }
                            </div>
                        </div>

                        @if (isEditMode)
                        {
                            <div class="row g-3 mt-2">
                                <div class="col-md-12">
                                    <label class="form-label fw-semibold">New Password</label>
                                    <InputText type="password"
                                               class="form-control"
                                               @bind-Value="editProfile.newHashPassword"
                                               placeholder="Enter new password" />
                                    <ValidationMessage For="@(() => editProfile.newHashPassword)" class="text-danger small" />
                                </div>
                            </div>
                        }

                        <div class="d-flex flex-column flex-md-row justify-content-end gap-3 mt-4">
                            @if (isEditMode)
                            {
                                <button type="button"
                                        class="btn btn-outline-secondary w-100 w-md-auto"
                                        @onclick="CancelEdit">
                                    Cancel
                                </button>

                                <button type="submit"
                                        class="btn btn-success w-100 w-md-auto">
                                    Save Changes
                                </button>
                            }
                            else
                            {
                                <button type="button"
                                        class="btn btn-success w-100 w-md-auto"
                                        @onclick="EnableEdit">
                                    Edit Profile
                                </button>
                            }
                        </div>

                    </EditForm>

                </div>
            </div>
        </div>
    </div>
}

@inject ChairpersonServices chairpersonServices
@inject ClaimServices claimServices
@inject IJSRuntime JS

@code {
    private bool loading = false;
    private bool isEditMode = false;
    private string error = "";

    private ViewMemberProfileDto? presidentProfile;

    private EditMemberProfileDto editProfile = new()
    {
        Name = "",
        Username = "",
        newHashPassword = ""
    };

    private EditMemberProfileDto? backupProfile;

    protected override async Task OnInitializedAsync()
    {
        loading = true;
        try
        {
            var claims = await claimServices.GetClaims();
            presidentProfile = await chairpersonServices.GetPresidentProfile(Guid.Parse(claims.Id));

            if (presidentProfile == null)
            {
                await JS.InvokeVoidAsync("alert", "No profile found.");
            }
            else
            {
                editProfile.Name = presidentProfile.Name ?? "";
                editProfile.Username = presidentProfile.Username ?? "";
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine(ex);
        }
        finally
        {
            loading = false;
        }
    }

    private void EnableEdit()
    {
        // Backup current values for cancel
        backupProfile = new EditMemberProfileDto
        {
            Name = editProfile.Name,
            Username = editProfile.Username,
            newHashPassword = ""
        };

        isEditMode = true;
    }

    private void CancelEdit()
    {
        if (backupProfile != null)
        {
            editProfile.Name = backupProfile.Name;
            editProfile.Username = backupProfile.Username;
            editProfile.newHashPassword = "";
        }

        error = "";
        isEditMode = false;
    }

    private async Task HandleUpdate()
    {
        error = "";

        try
        {
            var response = await chairpersonServices.UpdatePresidentProfile(presidentProfile!.Id, editProfile);

            if (response.Success)
            {
                await JS.InvokeVoidAsync("alert", "Profile updated successfully!");

                // Reflect changes in the view model
                presidentProfile!.Name = editProfile.Name;
                presidentProfile!.Username = editProfile.Username;
                editProfile.newHashPassword = "";
                isEditMode = false;
            }
            else
            {
                error = response.Error ?? "Something went wrong.";
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine(ex);
            error = "An unexpected error occurred.";
        }
    }
}
