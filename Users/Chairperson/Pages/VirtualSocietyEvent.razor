<div class="container mt-4">

    <div class="row g-4 mb-4">

        <!-- Event Details -->
        <div class="col-lg-6 col-md-12">
            <div class="card shadow-sm h-100">
                <div class="card-header fw-bold h4">
                    Event Details:
                </div>

                <div class="card-body">
                    <div class="mb-3">
                        <label class="form-label  fw-semibold">Event Name:</label>
                        <input class="form-control"
                               type="text"
                               @bind="event_name" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label  fw-semibold">Event Date:</label>
                        <input class="form-control"
                               type="date"
                               @bind="event_date" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Event Time:</label>

                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label text-muted">From</label>
                                <input class="form-control"
                                       type="time"
                                       @bind="startTime" />
                            </div>

                            <div class="col-md-6">
                                <label class="form-label text-muted">To</label>
                                <input class="form-control"
                                       type="time"
                                       @bind="endTime" />
                            </div>
                        </div>
                    </div>

                    @if (!string.IsNullOrEmpty(eventError))
                    {
                        <div class="alert alert-danger p-2">
                            @eventError
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Add Requirement -->
        <div class="col-lg-6 col-md-12">
            <div class="card shadow-sm h-100">
                <div class="card-header fw-bold h4">
                    Add Requirement:
                </div>

                <div class="card-body">
                    <div class="mb-3">
                        <label class="form-label">Type</label><br />

                        <div class="form-check form-check-inline">
                            <label class="form-check-label">
                                <input class="form-check-input"
                                       type="radio"
                                       name="type"
                                       value="financial"
                                       checked
                                       @onchange="OnStatusChanged" />
                                Financial
                            </label>
                        </div>

                        <div class="form-check form-check-inline">
                            <label class="form-check-label">
                                <input class="form-check-input"
                                       type="radio"
                                       name="type"
                                       value="non-financial"
                                       @onchange="OnStatusChanged" />
                                Non-Financial
                            </label>
                        </div>
                    </div>

                    @if (req_type == "financial")
                    {
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Name</label>
                                <input class="form-control" @bind="req_name" />
                            </div>

                            <div class="col-md-3 mb-3">
                                <label class="form-label">Qty</label>
                                <input class="form-control" type="number" @bind="req_qty" min="1" />
                            </div>

                            <div class="col-md-3 mb-3">
                                <label class="form-label">Price</label>
                                <input class="form-control"
                                       type="number"
                                       @bind="req_price"
                                       min="0" />
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Category</label>
                                <select class="form-select" @bind="main_type">
                                    @foreach (var option in nonFinancialOptions.GetAllTypes())
                                    {
                                        <option value="@option">@option</option>
                                    }
                                </select>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label class="form-label">@main_type</label>
                                @if (main_type == "LTs")
                                {
                                    <select class="form-select" @bind="req_name">
                                        @foreach (var option in nonFinancialOptions.GetAllLts())
                                        {
                                            <option value="@option">@option</option>
                                        }
                                    </select>
                                }
                                else if (main_type == "Labs")
                                {
                                    <select class="form-select" @bind="req_name">
                                        @foreach (var option in nonFinancialOptions.GetAllLabs())
                                        {
                                            <option value="@option">@option</option>
                                        }
                                    </select>
                                }
                                else if (main_type == "Other")
                                {
                                    <select class="form-select" @bind="req_name">
                                        <option value="">Select Requirement</option>
                                        @foreach (var option in nonFinancialOptions.GetAllOthers())
                                        {
                                            <option value="@option">@option</option>
                                        }
                                    </select>
                                }
                            </div>

                            <div class="col-md-6 mb-3">
                                <label class="form-label">Other Type</label>
                                <input disabled="@(main_type != "Other")"
                                       class="form-control"
                                       type="text"
                                       @bind="req_name"
                                       placeholder="Type custom requirement..." />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-semibold">Qty</label>
                                <input type="number"
                                       class="form-control"
                                       @bind="req_qty"
                                       min="1"
                                       disabled="@(main_type != "Other")" />
                            </div>
                        </div>
                    }


                    @if (!string.IsNullOrEmpty(reqError))
                    {
                        <div class="alert alert-danger p-2">
                            @reqError
                        </div>
                    }

                    <div class="d-flex gap-2">
                        <button class="btn btn-primary"
                                @onclick="HandleAddRequirement">
                            Add Requirement
                        </button>

                        <button class="btn btn-secondary"
                                @onclick="ClearForm"
                                disabled="@(!isEditMode)">
                            Cancel
                        </button>
                    </div>
                </div>
            </div>
        </div>

    </div>
</div>



<!-- Table to show requirements -->
<div class="card shadow-sm mb-4">
    <div class="card-header fw-bold h4">
        Requirements List:
    </div>

    <div class="card-body p-0">
        <table class="table table-striped mb-0">
            <thead class="table-light">
                <tr>
                    <th>Type</th>
                    <th>Name</th>
                    <th>Qty</th>
                    <th>Price</th>
                    <th style="width:150px">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var req in requirements)
                {
                    <tr>
                        <td>@req.Type</td>
                        <td>@req.Name</td>
                        <td>@req.Quantity</td>
                        <td>@req.Price</td>
                        <td>
                            <button class="btn btn-sm btn-danger"
                                    @onclick="() => HandleDelete(req)">
                                Delete
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>


<div class="row my-3 justify-content-end">
    <div class="col-auto col-md-auto">
        <button class="btn btn-success w-100 fw-bold py-2"
                @onclick="HandlCreateEvent">
            Create Event
        </button>
    </div>
</div>

<p>@VirtualSocietyId</p>

@inject ChairpersonServices chairpersonServices
@inject ClaimServices claimServices
@inject NavigationManager nav
@inject IJSRuntime JS
@code {
    [Parameter] 
    public Guid VirtualSocietyId { get; set; }

    private NonFinancial_Req nonFinancialOptions = new();
    private string event_name = "";
    private DateTime event_date = DateTime.Now; // Fixed: Use FromDateTime static method

    // --- FIX: Use TimeOnly for time fields to match <input type="time"> binding ---
    private TimeOnly startTime = new TimeOnly(12, 0, 0);
    private TimeOnly endTime = new TimeOnly(12, 0, 0);
    // --- END FIX ---

    private string req_type = "financial";
    private string req_name = "";
    private string main_type = "LTs";
    private int req_qty;
    private decimal req_price;
    private string? eventError;
    private string? reqError;

    private bool isEditMode = false;
    private EventRequirementDto? selectedRequirement;

    List<EventRequirementDto> requirements = new();

    private string HandleTime()
    {
        var start = startTime.ToTimeSpan();
        var end = endTime.ToTimeSpan();

        if (start >= end)
        {
            Console.WriteLine($"{start}, {end}, {start >= end}");
            return "End time must be greater then start time";
        }
        else if ((end - start) < TimeSpan.FromHours(1))
        {
            Console.WriteLine($"{start}, {end}, {start - end}");
            return "Event duration must be at least 1 hour";
        }
        return null!;
    }

    private async Task HandleDelete(EventRequirementDto req)
    {
        bool confirmDelete = await JS.InvokeAsync<bool>("confirm", $"Delete {req.Name}?");

        if (confirmDelete)
        {
            requirements.Remove(req);
            ClearForm();
        }
    }

    private void ClearForm()
    {
        // req_type = "financial";
        req_name = "";
        req_qty = 0;
        req_price = 0;
        isEditMode = false;
        selectedRequirement = null;
    }


    private void OnStatusChanged(ChangeEventArgs e)
    {
        req_type = e.Value?.ToString() ?? "financial";

        if (req_type == "non-financial")
        {
            req_price = 0;
        }
    }

    private void HandleAddRequirement()
    {
        reqError = null;

        if (string.IsNullOrWhiteSpace(req_name) || string.IsNullOrWhiteSpace(req_type) || req_qty < 0)
        {
            reqError = "Requirement type, name and quantity are required.";
            return;
        }

        if (req_type == "financial" && req_price == 0)
        {
            reqError = "Price can't be zero for finential Requirement";
            return;
        }

        decimal finalPrice = req_type == "non-financial" ? 0 : req_price;


        requirements.Add(new EventRequirementDto
        {
            Type = req_type,
            Name = req_name,
            Quantity = req_qty,
            Price = finalPrice
        });


        ClearForm();
    }

    private async Task HandlCreateEvent()
    {
        eventError = null;
        reqError = null;

        if (string.IsNullOrWhiteSpace(event_name))
        {
            eventError = "Event name is required.";
            return;
        }

        if (requirements.Count == 0)
        {
            eventError = "At least one requirement is required.";
            return;
        }

        if (event_date < DateTime.Now)
        {
            eventError = "Invalid Date";
            return;
        }

        string TimeError = HandleTime();
        if (!String.IsNullOrEmpty(TimeError))
        {
            eventError = TimeError;
            return;
        }

        if (isEditMode)
        {
            reqError = "Update Requirement First";
            return;
        }

        var dto = new AddVirtualSocietyEventDto()
        {
            Name = event_name,
            EventDate = event_date,
            StartTime = startTime.ToTimeSpan(),
            EndTime = endTime.ToTimeSpan(),
            VirtualSocietyId = VirtualSocietyId,
            Requirements = requirements
        };

        var response = await chairpersonServices.CreateVirtualSocietyEvent(dto);
        if (response?.Success == true)
        {
            await JS.InvokeVoidAsync("alert", "Event added successfully.");
            // CloseAllModals();
            await OnParametersSetAsync();
        }
        else
        {
            await JS.InvokeVoidAsync("alert", $"Failed to add event: {response?.Error}");
        }
    }
}
