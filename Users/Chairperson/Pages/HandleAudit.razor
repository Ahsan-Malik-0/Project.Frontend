@page "/chairperson/handle-audit"
@layout ChairpersonLayout
@attribute [Authorize(Roles = "chairperson")]

<div class="container py-4">

    <h4 class="fw-bold mb-4">@(isEditMode ? "Update Audit" : "Create Audit")</h4>

    <div class="row g-4">

        <!-- ===== LEFT: Audit Summary Fields ===== -->
        <div class="col-lg-6 col-md-12">
            <div class="card shadow-sm h-100">
                <div class="card-header fw-bold h5 mb-0">Audit Details</div>
                <div class="card-body">

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Fund Provided <span class="text-danger">*</span></label>
                        <div class="input-group">
                            <span class="input-group-text">Rs</span>
                            @if (isEditMode)
                            {
                                <input type="number" class="form-control" min="0"
                                value="@fundProvided"
                                disabled />
                            }
                            else
                            {
                                <input type="number" class="form-control" min="0"
                                value="@AllotedAmount"
                                disabled/>
                            }
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Amount Spent <span class="text-danger">*</span></label>
                        <div class="input-group">
                            <span class="input-group-text">Rs</span>
                            <input type="number" class="form-control" min="0"
                                   value="@TotalSpent"
                                   disabled
                                   placeholder="Auto-calculated from spends" />
                        </div>
                        <div class="form-text text-muted">Auto-calculated from spend entries below.</div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Revenue Generated</label>
                        <div class="input-group">
                            <span class="input-group-text">Rs</span>
                            <input type="number" class="form-control" min="0"
                                   @bind="revenueGenerated"
                                   placeholder="0.00" />
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Remaining Amount</label>
                        <div class="input-group">
                            <span class="input-group-text">Rs</span>
                            <input type="number" class="form-control"
                                   value="@RemainingAmount"
                                   disabled />
                        </div>
                        <div class="form-text text-muted">Fund Provided − Amount Spent + Revenue Generated.</div>
                    </div>

                    @if (!string.IsNullOrEmpty(formError))
                    {
                        <div class="alert alert-danger p-2 small">@formError</div>
                    }

                </div>
            </div>
        </div>

        <!-- ===== RIGHT: Add Spend ===== -->
        <div class="col-lg-6 col-md-12">
            <div class="card shadow-sm h-100">
                <div class="card-header fw-bold h5 mb-0">
                    @(isSpendEditMode ? "Edit Spend" : "Add Spend")
                </div>
                <div class="card-body">

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Vendor Name <span class="text-danger">*</span></label>
                        <input class="form-control"
                               @bind="spend_vendor"
                               placeholder="e.g. Al-Fatah Store" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Description</label>
                        <input class="form-control"
                               @bind="spend_description"
                               placeholder="Optional description" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Amount <span class="text-danger">*</span></label>
                        <div class="input-group">
                            <span class="input-group-text">Rs</span>
                            <input type="number" class="form-control" min="0"
                                   @bind="spend_amount"
                                   placeholder="0.00" />
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Receipt Picture</label>
                        <InputFile OnChange="HandleFileSelection"
                                   accept=".jpg,.jpeg,.png"
                                   class="form-control form-control-sm" />
                        @if (!string.IsNullOrEmpty(spend_receiptPreview))
                        {
                            <img src="@spend_receiptPreview"
                                 class="img-thumbnail mt-2"
                                 style="max-height:120px;object-fit:cover;" />
                        }
                    </div>

                    @if (!string.IsNullOrEmpty(spendError))
                    {
                        <div class="alert alert-danger p-2 small">@spendError</div>
                    }

                    <div class="d-flex gap-2">
                        <button class="btn btn-primary"
                                @onclick="HandleAddOrUpdateSpend">
                            @(isSpendEditMode ? "Update Spend" : "Add Spend")
                        </button>
                        <button class="btn btn-secondary"
                                disabled="@(!isSpendEditMode)"
                                @onclick="ClearSpendForm">
                            Cancel
                        </button>
                    </div>

                </div>
            </div>
        </div>

        <!-- ===== BOTTOM: Spends Table ===== -->
        <div class="col-12">
            <div class="card shadow-sm">
                <div class="card-header fw-bold h5 mb-0">Spends List</div>
                <div class="card-body p-0">
                    @if (!spends.Any())
                    {
                        <p class="text-center text-muted py-4 mb-0 small">
                            No spends added yet. Use the form above to add spend entries.
                        </p>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-striped table-bordered align-middle mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th class="small">#</th>
                                        <th class="small">Vendor</th>
                                        <th class="small">Description</th>
                                        <th class="small text-end">Amount</th>
                                        <th class="small text-center">Receipt</th>
                                        <th class="small text-center" style="width:120px">Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @{ int i = 1; }
                                    @foreach (var s in spends)
                                    {
                                        var idx = i - 1;
                                        <tr>
                                            <td class="text-muted">@i</td>
                                            <td>@s.VenderName</td>
                                            <td class="text-muted small">@(s.ItemDescription ?? "—")</td>
                                            <td class="text-end fw-semibold">Rs @s.Amount.ToString("N0")</td>
                                            <td class="text-center">
                                                @if (!string.IsNullOrEmpty(s.ReceiptPicture))
                                                {
                                                    <img src="@($"data:image/png;base64,{s.ReceiptPicture}")"
                                                         style="height:36px;width:36px;object-fit:cover;"
                                                         class="rounded border" />
                                                }
                                                else
                                                {
                                                    <span class="text-muted small">—</span>
                                                }
                                            </td>
                                            <td class="text-center d-flex gap-1 justify-content-center">
                                                <button class="btn btn-sm btn-warning me-1"
                                                        disabled="@isSpendEditMode"
                                                        @onclick="() => HandleEdit(idx)">
                                                    Edit
                                                </button>
                                                <button class="btn btn-sm btn-danger"
                                                        disabled="@isSpendEditMode"
                                                        @onclick="() => HandleDelete(idx)">
                                                    Delete
                                                </button>
                                            </td>
                                        </tr>
                                        i++;
                                    }
                                </tbody>
                                <tfoot class="table-light">
                                    <tr>
                                        <td colspan="3" class="text-end fw-bold">Total Spent:</td>
                                        <td class="text-end fw-bold text-danger">Rs @TotalSpent.ToString("N0")</td>
                                        <td colspan="2"></td>
                                    </tr>
                                </tfoot>
                            </table>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- ===== Submit / Cancel ===== -->
        <div class="col-12 d-flex justify-content-end gap-3">
            <button class="btn btn-outline-secondary px-4" @onclick="HandleCancel">Cancel</button>
            <button class="btn btn-success px-4" @onclick="HandleSubmit">
                @(isEditMode ? "Update Audit" : "Create Audit")
            </button>
        </div>

    </div>
</div>


@inject ChairpersonServices chairpersonServices
@inject NavigationManager nav
@inject IJSRuntime JS

@code {
    [SupplyParameterFromQuery(Name = "eventId")]
    public Guid? EventId { get; set; }

    [SupplyParameterFromQuery(Name = "AllotedAmount")]
    public string? AllotedAmount { get; set; }

    [SupplyParameterFromQuery(Name = "auditId")]
    public Guid? AuditId { get; set; }

    private bool isEditMode => AuditId.HasValue;

    // ── Audit fields ─────────────────────────────────────────
    private decimal fundProvided = 0;
    private decimal revenueGenerated = 0;
    private string? formError;

    private decimal TotalSpent => spends.Sum(s => s.Amount);
    private decimal RemainingAmount => AuditId.HasValue ? fundProvided - TotalSpent + revenueGenerated : (AllotedAmount != null ? decimal.Parse(AllotedAmount) : 0) - TotalSpent + revenueGenerated;

    // ── Spends list ──────────────────────────────────────────
    private List<CreateAuditSpendDto> spends = new();

    // ── Spend form fields ────────────────────────────────────
    private string spend_vendor = "";
    private string? spend_description;
    private decimal spend_amount = 0;
    private string? spend_receiptBase64;
    private string? spend_receiptPreview;
    private string? spendError;
    private bool isSpendEditMode = false;
    private int? selectedSpendIndex = null;

    // ── Load existing data for edit mode ─────────────────────
    protected override async Task OnParametersSetAsync()
    {
        if (EventId == null)
        {
            nav.NavigateTo("/chairperson/history");
            return;
        }

        if (isEditMode)
        {
            try
            {
                var audit = await chairpersonServices.GetEventAudit(EventId.Value);
                if (audit == null)
                {
                    await JS.InvokeVoidAsync("alert", "Audit not found.");
                    nav.NavigateTo("/chairperson/history");
                    return;
                }

                fundProvided = audit.FundProvided;
                revenueGenerated = audit.RevenueGenerated;

                spends.Clear();
                if (audit.Spends != null)
                {
                    foreach (var s in audit.Spends)
                    {
                        spends.Add(new CreateAuditSpendDto
                        {
                            VenderName = s.Vender,
                            ItemDescription = s.Description,
                            Amount = s.Amount,
                            ReceiptPicture = s.ReceiptPicture
                        });
                    }
                }
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error loading audit: {ex.Message}");
                await JS.InvokeVoidAsync("alert", "Failed to load audit details.");
                nav.NavigateTo("/chairperson/history");
            }
        }
    }

    // ── File Selection ───────────────────────────────────────
    private async Task HandleFileSelection(InputFileChangeEventArgs e)
    {
        var file = e.File;
        using var stream = file.OpenReadStream(maxAllowedSize: 5 * 1024 * 1024);
        using var ms = new MemoryStream();
        await stream.CopyToAsync(ms);
        spend_receiptBase64 = Convert.ToBase64String(ms.ToArray());
        spend_receiptPreview = $"data:{file.ContentType};base64,{spend_receiptBase64}";
    }

    // ── Spend Actions ────────────────────────────────────────
    private void HandleAddOrUpdateSpend()
    {
        spendError = null;

        if (string.IsNullOrWhiteSpace(spend_vendor))
        {
            spendError = "Vendor name is required.";
            return;
        }
        if (spend_amount <= 0)
        {
            spendError = "Amount must be greater than zero.";
            return;
        }

        var dto = new CreateAuditSpendDto
        {
            VenderName = spend_vendor.Trim(),
            ItemDescription = string.IsNullOrWhiteSpace(spend_description) ? null : spend_description.Trim(),
            Amount = spend_amount,
            ReceiptPicture = spend_receiptBase64
        };

        if (isSpendEditMode && selectedSpendIndex.HasValue)
            spends[selectedSpendIndex.Value] = dto;
        else
            spends.Add(dto);

        ClearSpendForm();
    }

    private void HandleEdit(int index)
    {
        var s = spends[index];
        spend_vendor = s.VenderName;
        spend_description = s.ItemDescription;
        spend_amount = s.Amount;
        spend_receiptBase64 = s.ReceiptPicture;
        spend_receiptPreview = string.IsNullOrEmpty(s.ReceiptPicture)
            ? null
            : $"data:image/png;base64,{s.ReceiptPicture}";
        selectedSpendIndex = index;
        isSpendEditMode = true;
        spendError = null;
    }

    private async Task HandleDelete(int index)
    {
        bool confirm = await JS.InvokeAsync<bool>("confirm", $"Delete spend from \"{spends[index].VenderName}\"?");
        if (confirm)
        {
            spends.RemoveAt(index);
            ClearSpendForm();
        }
    }

    private void ClearSpendForm()
    {
        spend_vendor = "";
        spend_description = null;
        spend_amount = 0;
        spend_receiptBase64 = null;
        spend_receiptPreview = null;
        selectedSpendIndex = null;
        isSpendEditMode = false;
        spendError = null;
    }

    // ── Submit ───────────────────────────────────────────────
    private async Task HandleSubmit()
    {
        formError = null;

        if (!spends.Any())
        {
            formError = "At least one spend entry is required.";
            return;
        }
        if (isSpendEditMode)
        {
            formError = "Please finish editing the spend entry first.";
            return;
        }

        try
        {
            if (isEditMode)
            {
                var updateDto = new UpdateEventAuditDto
                {
                    FundProvided = fundProvided,
                    SpendAmount = TotalSpent,
                    RevenueGenerated = revenueGenerated,
                    RemainingAmount = RemainingAmount,
                    Spends = spends.Select(s => new UpdateAuditSpendDto
                    {
                        VenderName = s.VenderName,
                        ItemDescription = s.ItemDescription,
                        Amount = s.Amount,
                        ReceiptPicture = s.ReceiptPicture
                    }).ToList()
                };

                var response = await chairpersonServices.UpdateEventAudit(AuditId!.Value, updateDto);
                if (response?.Success == true)
                {
                    await JS.InvokeVoidAsync("alert", "Audit updated successfully!");
                    nav.NavigateTo("/chairperson/history");
                }
                else
                {
                    formError = response?.Error ?? "Failed to update audit.";
                }
            }
            else
            {
                var createDto = new CreateEventAuditDto
                {
                    FundProvided = AllotedAmount != null ? decimal.Parse(AllotedAmount) : 0,
                    SpendAmount = TotalSpent,
                    RevenueGenerated = revenueGenerated,
                    RemainingAmount = RemainingAmount,
                    EventId = EventId!.Value,
                    Spends = spends
                };

                var response = await chairpersonServices.CreateEventAudit(createDto);
                if (response?.Success == true)
                {
                    await JS.InvokeVoidAsync("alert", "Audit created successfully!");
                    nav.NavigateTo("/chairperson/history");
                }
                else
                {
                    formError = response?.Error ?? "Failed to create audit.";
                }
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error submitting audit: {ex.Message}");
            formError = "An error occurred. Please try again.";
        }
    }

    private async Task HandleCancel()
    {
        bool confirm = await JS.InvokeAsync<bool>("confirm", "Are you sure you want to cancel?");
        if (confirm)
            nav.NavigateTo("/chairperson/history");
    }
}
