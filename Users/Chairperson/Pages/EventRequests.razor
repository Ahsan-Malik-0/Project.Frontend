@page "/chairperson/events-requests"
@using System.Globalization
@layout ChairpersonLayout

@attribute [Authorize(Roles = "chairperson")]

<div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mb-4">
    <h4 class="fw-bold mb-3">Event Request:</h4>

    @if (String.IsNullOrEmpty(remainingCredits))
    {
        <h6 class="fw-bold text-muted text-danger">Create Yearly Budget </h6>
    }
    else if (remainingCredits == "1")
    {
        <h6 class="fw-bold text-muted text-secondary">Budget not alloted yet</h6>
    }
    else
    {
        <h6 class="fw-bold text-muted @(remainingCredits == "0" ? "text-danger" : "text-success")">Remaining Budget: @remainingCredits</h6>
    }
</div>

@if (loading)
{
    <p class="text-center text-muted">Loading events</p>
}
else if (events.Count == 0)
{
    <p class="text-center text-muted">No pending events available</p>
}
else
{
    <div class="row g-4">
        @foreach (var _event in events)
        {
            var modalId = $"eventDetailsModal-{_event.Id}";

            TimeOnly st = TimeOnly.ParseExact(_event.StartTime.ToString(), "HH:mm:ss", CultureInfo.InvariantCulture);
            string startTime = st.ToString("h:mm tt", CultureInfo.InvariantCulture);

            TimeOnly et = TimeOnly.ParseExact(_event.EndTime.ToString(), "HH:mm:ss", CultureInfo.InvariantCulture);
            string endTime = et.ToString("h:mm tt", CultureInfo.InvariantCulture);

            <div class="col-lg-4 col-md-6">
                <div class="card h-100 shadow-sm border">

                    <!-- Title + Status -->
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <h6 class="fw-bold mb-0">@_event.Name</h6>
                        @* 
                            <span
                                class="badge @(_event.Status == "Approved" ? "bg-success" : _event.Status == "Pending" ? "bg-warning text-dark" : "bg-danger")">
                                @_event.Status
                            </span> *@
                    </div>
                    

                    <div class="card-body d-flex flex-column">
                        <p class="text-muted small mb-1">
                            <strong>Event Date:</strong> @_event.EventDate.ToString("dd MMM yyyy")
                        </p>
                        <p class="text-muted small mb-1">
                            <strong> Slot: </strong>
                            @startTime <span class="fw-semibold">to</span> @endTime
                        </p>

                        <p class="text-muted small mb-3">
                            @* <strong>Status:</strong> @_event.Status *@
                            <strong class="fw-semibold">Budget:</strong> 
                            @(_event.Requirements?.Sum(r => r.Price * r.Quantity) ?? 0)
                        </p>

                        <!-- Button -->
                        <div class="d-flex gap-2 mb-1">
                            <button class="btn btn-sm btn-outline-primary w-100" 
                                    @onclick="() => CreateRequisition(_event.Id)">
                                    Create Requisition
                            </button>
                            <button class="btn btn-sm btn-outline-primary w-100"
                                    @onclick="() => HandleShowDetails(_event)">
                                View Details
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}

<!-- ===== MODAL: View Details ===== -->
@if (showViewDetails)
{
    <div class="modal fade show d-block" tabindex="-1" style="background:rgba(0,0,0,0.5)">
        <div class="modal-dialog modal-lg modal-dialog-centered modal-dialog-scrollable">
            <div class="modal-content border-0 shadow">
                <div class="modal-header bg-light border-bottom">
                    <h5 class="modal-title fw-bold">
                        @selectedEvent?.Name
                    </h5>

                    <button type="button"
                            class="btn-close"
                            @onclick="CloseViewDetailsModal">
                    </button>
                </div>

                <div class="modal-body p-4">

                    <!-- Event Information -->
                    <div class="card border-0 shadow-sm mb-4">
                        <div class="card-body">

                            <div class="row g-3">

                                <div class="col-md-6">
                                    <div class="text-muted small">
                                        Event Date
                                    </div>

                                    <div class="fw-semibold fs-6">
                                        <i class="bi bi-calendar-event me-2"></i>

                                        <span class="@(selectedEvent?.EventDate < DateTime.Now ? "text-danger" : "")">
                                            @selectedEvent?.EventDate.ToString("dd MMM yyyy")
                                        </span>
                                    </div>
                                </div>

                                <div class="col-md-6">
                                    <div class="text-muted small">
                                        Time Slot
                                    </div>

                                    <div class="fw-semibold fs-6">
                                        <i class="bi bi-clock me-2"></i>
                                        @selectedEvent?.StartTime -
                                        @selectedEvent?.EndTime
                                    </div>
                                </div>

                            </div>

                        </div>
                    </div>

                    <!-- Requirements -->
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h6 class="fw-bold mb-0">
                            Requirements
                        </h6>

                        <span class="badge bg-primary">
                            @(selectedEvent?.Requirements?.Count ?? 0) Items
                        </span>
                    </div>

                    @if (selectedEvent?.Requirements?.Any() == true)
                    {
                        <div class="table-responsive">

                            <table class="table table-hover align-middle border">

                                <thead class="table-light">
                                    <tr>
                                        <th>Type</th>
                                        <th>Name</th>
                                        <th class="text-center">Qty</th>
                                        <th class="text-end">Unit Price</th>
                                        <th class="text-end">Amount</th>
                                    </tr>
                                </thead>

                                <tbody>
                                    @foreach (var req in selectedEvent.Requirements)
                                    {
                                        <tr>
                                            <td>
                                                <span class="badge @(req.Type == "financial" ? "bg-success" : "bg-warning text-dark")">
                                                    @req.Type
                                                </span>
                                            </td>

                                            <td>@req.Name</td>

                                            <td class="text-center">
                                                @req.Quantity
                                            </td>

                                            <td class="text-end">
                                                Rs. @req.Price
                                            </td>

                                            <td class="text-end fw-semibold">
                                                Rs. @(req.Price* req.Quantity)
                                            </td>
                                        </tr>
                                    }
                                </tbody>

                            </table>

                        </div>

                        <div class="card bg-light border-0 mt-3">
                            <div class="card-body py-3">

                                <div class="d-flex justify-content-between align-items-center">

                                    <span class="fw-semibold fs-5">
                                        Total Cost
                                    </span>

                                    <span class="fw-bold fs-4 text-primary">
                                        Rs. @(selectedEvent.Requirements.Sum(r => r.Price * r.Quantity))
                                    </span>

                                </div>

                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-light text-center border">
                            No requirements available.
                        </div>
                    }

                </div>

                <div class="modal-footer bg-light border-top">
                    <div class="d-flex gap-2 mb-1">
                        <button class="btn btn-sm btn-outline-primary w-100"
                                @onclick="() => EditEvent(selectedEvent!.Id)">
                            Edit
                        </button>
                        <button class="btn btn-sm btn-outline-danger w-100"
                                @onclick="() => DeleteEvent(selectedEvent!)">
                            Delete
                        </button>
                    </div>
                    <div class="d-flex gap-2 mb-1">
                        <button class="btn btn-sm btn-outline-danger w-100"
                                @onclick="() => HandleShowRejection(selectedEvent!)">
                            Reject
                        </button>
                        <button class="btn btn-sm btn-outline-warning w-100"
                                @onclick="() => PostponeEvent(selectedEvent!)">
                            Postpone
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

<!-- ===== MODAL: View Details ===== -->
@if (showRejectModel)
{
    <div class="modal fade show d-block" tabindex="-1" style="background:rgba(0,0,0,0.5)">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow">
                <div class="modal-header bg-light border-bottom">
                    <h5 class="modal-title fw-bold">
                        Reject Event
                    </h5>

                    <button type="button"
                    class="btn-close"
                    @onclick="CloseRejectModel">
                    </button>
                </div>

                <div class="modal-body p-4">

                    <label class="form-label fw-semibold">
                        Message
                    </label>

                    <textarea class="form-control"
                    rows="4"
                    placeholder="Write rejection reason..."
                    @bind="rejectMessage"></textarea>

                </div>

                <div class="modal-footer bg-light border-top">
                    <button class="btn btn-secondary"
                    @onclick="CloseRejectModel">
                        Cancel
                    </button>

                    <button class="btn btn-danger"
                    data-bs-dismiss="modal"
                    @onclick="() => SendRejection(selectedEvent!)">
                        Send
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@inject ClaimServices claimServices
@inject ChairpersonServices chairpersonServices
@inject IJSRuntime JS
@inject NavigationManager nav
@code {

    private string id = "";
    private bool loading = false;
    private List<Event> events = new();
    private Event? selectedEvent;
    TimeOnly startTime = new TimeOnly(12, 00, 00);
    private List<Event> addedEvents = new();
    string rejectMessage = "";

    private string? remainingCredits;

    // Models
    private bool showViewDetails;
    private bool showRejectModel;

    void CloseViewDetailsModal()
    {
        showViewDetails = false;
    }

    void CloseRejectModel()
    {
        showRejectModel = false;
    }

    void HandleShowDetails(Event ev)
    {
        showViewDetails = true;
        selectedEvent = ev;
    }

    void HandleShowRejection(Event ev)
    {
        selectedEvent = ev;
    }

    private async Task SendRejection(Event rejectedEvent)
    {
        if (selectedEvent == null)
            return;

        if (string.IsNullOrWhiteSpace(rejectMessage))
        {
            await JS.InvokeVoidAsync("alert", "Please enter rejection message");
            return;
        }
        else
        {
            UpdateEventStatusDto updateEventStatus = new UpdateEventStatusDto()
            {
                Id = rejectedEvent.Id,
                Status = "rejected",
                Message = rejectMessage
            };

            var response = await chairpersonServices.RejectEvent(updateEventStatus);

            if(response.Success)
                await JS.InvokeVoidAsync("alert", "Event rejected successfully");
            else
                await JS.InvokeVoidAsync("alert", $"An error accure while rejecting the event: {response.Error}"); 

            rejectMessage = "";
            await OnInitializedAsync();
        }
    }

    protected override async Task OnInitializedAsync()
    {
        loading = true;
        var claims = await claimServices.GetClaims();
        id = claims.Id;

        try
        {
            events = (await chairpersonServices.GetPendingEvents(Guid.Parse(id)))
            .OrderByDescending(e => e.EventDate.Date)
            .ToList();

            var result = await chairpersonServices.GetRemainigYearlyBudge(Guid.Parse(id));
            remainingCredits = result.ToString() ?? null;
        }
        catch (Exception ex)
        {
            Console.WriteLine("Error:", ex);
        }
        finally
        {
            loading = false;
        }
    }


    private void EditEvent(Guid id)
    {
        nav.NavigateTo($"chairperson/edit-event?id={id}");
    }

    private async Task PostponeEvent(Event @event)
    {
        var conformation = await JS.InvokeAsync<bool>("confirm", $"Are you sure you want to Postpone {@event.Name}");
        if (conformation)
        {
            var response = await chairpersonServices.PostponeEvent(@event.Id);

            if (!response.Success)
            {
                await JS.InvokeVoidAsync("alert", $"Event not pontpone due to {response.Error}");
            }
            else
            {
                await JS.InvokeVoidAsync("alert", $"{@event.Name} has been postponed Successfully");
                await OnInitializedAsync();
            }
        }
    }

    private void CreateRequisition(Guid id)
    {
        nav.NavigateTo($"chairperson/create-requisition?id={id}");
    }


    private async Task DeleteEvent(Event @event)
    {

        bool confirmDelete = await JS.InvokeAsync<bool>("confirm", $"Are you sure you want to delete {@event.Name}");

        if (confirmDelete)
        {
            var response = await chairpersonServices.DeleteEvent(@event.Id);

            if (!response.Success)
            {
                await JS.InvokeVoidAsync("alert", $"Event not delete due to {response.Error}");
            }
            else
            {
                await JS.InvokeVoidAsync("alert", $"{@event.Name} has been deleted Successfully");
                await OnInitializedAsync();
            }
        }
    }
}