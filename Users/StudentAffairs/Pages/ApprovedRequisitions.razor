@page "/studentAffairs/approvedRequisitions"

@layout StudentAffairsLayout
@attribute [Authorize(Roles = "studentAffairs")]

@if (loading)
{
    <div class="text-center py-5">
        <div class="spinner-border text-primary"></div>
        <p class="mt-3 text-muted">Loading Pending Requisitions...</p>
    </div>
}
else if (approvedEventRequisitions.Count == 0)
{
    <div class="text-center py-5">
        <p class="text-muted fs-5">No approved requisitions available</p>
    </div>
}
else
{
    <h4 class="fw-bold mb-3">Approved Requisitions:</h4>
    <div class="row g-4">
        @foreach (var pr in approvedEventRequisitions)
        {
            bool isRejected = pr.Status.Contains("Reject", StringComparison.OrdinalIgnoreCase);
            bool hasReviewMessage = !string.IsNullOrWhiteSpace(pr.ReviewMessage);

            <div class="col-lg-4 col-md-6">
                <div class="card h-100 shadow-sm border">

                    <!-- Header -->
                    <div class="card-header">
                        <div class="d-flex justify-content-between align-items-center">
                            <h6 class="fw-bold mb-0">@pr.SocietyName</h6>
                            <div>
                                <button class="btn btn-sm btn-outline-info me-1" @onclick="() => OpenStatusModal(pr.Status)">
                                    <i class="bi bi-bar-chart-steps me-1"></i> Track Status
                                </button>
                                @if (hasReviewMessage)
                                {
                                    <button class="btn btn-sm btn-outline-secondary flex-shrink-0" title="Review Message"
                                            @onclick="() => OpenReviewMessageModal(pr.ReviewMessage!)">
                                        <i class="bi bi-envelope-fill text-success"></i>
                                    </button>
                                }
                            </div>
                        </div>
                    </div>

                    <div class="card-body d-flex flex-column">
                        <p class="text-muted small mb-2">
                            <strong>Event Name:</strong> @pr.EventName
                        </p>
                        <p class="text-muted small mb-2">
                            <strong>Event Date:</strong> @pr.EventDate.ToString("dd MMM yyyy")
                        </p>

                        <p class="text-muted small mb-2">
                            <strong>Event Status:</strong> <span class="@GetStatusTextClass(pr.Status)">@pr.Status</span>
                        </p>
                        <p class="text-muted small mb-2">
                            <strong>Alloted Budget:</strong>
                            <span class="fw-semibold text-primary">Rs @pr.AllotedBudget.ToString("N0")</span>
                        </p>
                        <p class="mb-2 small">
                            <strong class="text-muted">BIIT Contribution:</strong>
                            <span class="fw-semibold text-primary ms-1">Rs @pr.BiitContribution.ToString("N0")</span>
                        </p>
                        <p class="mb-2 small">
                            <strong class="text-muted">Total:</strong>
                            <span class="fw-semibold text-success ms-1">Rs @((pr.AllotedBudget + pr.BiitContribution).ToString("N0"))</span>
                        </p>
                    </div>

                    <!-- Action Buttons -->
                    <div class="mt-auto card-footer bg-white border-top d-flex gap-2 px-3 pt-2">
                        <button
                            class="btn btn-outline-primary btn-sm @(pr.Status == "Budget Released By Finance" ? "flex-fill" : "w-100")"
                            @onclick="() => OpenViewModal(pr.RequisitionId)">
                            View Requisition
                        </button>

                        @if (pr.Status == "Budget Released By Finance")
                        {
                            <button class="btn btn-outline-success btn-sm flex-fill"
                                    @onclick="() => HandleCompleted(pr.RequisitionId)">
                                Mark as Completed
                            </button>
                        }
                    </div>
                    
                </div>
            </div>
        }
    </div>
}


    <!-- ===== MODAL: Status Tracker ===== -->
    @if (showStatusModal)
    {
        <div class="modal fade show d-block" tabindex="-1" style="background:rgba(0,0,0,0.5)">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content border-0 shadow">
                    <div class="modal-header border-bottom">
                        <h6 class="modal-title fw-bold">
                            <i class="bi bi-bar-chart-steps me-2"></i>Requisition Status
                        </h6>
                        <button class="btn-close" @onclick="CloseAllModals"></button>
                    </div>
                    <div class="modal-body py-4 px-4">
                        <ul class="list-unstyled mb-0">
                            @foreach (var step in GetStatusSteps(activeStatus))
                            {
                                <li class="d-flex align-items-start gap-3 mb-4">
                                    <!-- Icon circle -->
                                    <div class="rounded-circle d-flex align-items-center justify-content-center flex-shrink-0"
                                         style="width:36px;height:36px;background-color:@step.CircleColor">
                                        <i class="bi @step.Icon" style="color:white;font-size:0.85rem;"></i>
                                    </div>
                                    <!-- Label -->
                                    <div>
                                        <p class="mb-0 fw-semibold @step.TextClass">@step.Label</p>
                                        @if (!string.IsNullOrEmpty(step.SubLabel))
                                        {
                                            <small class="text-muted">@step.SubLabel</small>
                                        }
                                    </div>
                                </li>
                            }
                        </ul>
                    </div>
                    <div class="modal-footer border-top">
                        <button class="btn btn-secondary btn-sm" @onclick="CloseAllModals">Close</button>
                    </div>
                </div>
            </div>
        </div>
    }

    <!-- ===== MODAL: Message ===== -->
    @if (showReviewModal)
    {
        <div class="modal fade show d-block" tabindex="-1" style="background:rgba(0,0,0,0.5)">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content border-0 shadow">
                    <div class="modal-header border-bottom">
                        <h6 class="modal-title fw-bold">
                            <i class="bi bi-envelope-fill text-primary me-2"></i>Current Message
                        </h6>
                        <button class="btn-close" @onclick="CloseAllModals"></button>
                    </div>
                    <div class="modal-body">
                        <p class="mt-3 mb-0">@activeReviewMessage</p>
                    </div>
                    <div class="modal-footer border-top">
                        <button class="btn btn-secondary btn-sm" @onclick="CloseAllModals">Close</button>
                    </div>
                </div>
            </div>
        </div>
    }

    <!-- ===== MODAL: View Requisition ===== -->
    @if (showViewModal)
    {
        <div class="modal fade show d-block" tabindex="-1" style="background:rgba(0,0,0,0.5)">
            <div class="modal-dialog modal-xl modal-dialog-centered modal-dialog-scrollable">
                <div class="modal-content border-0 shadow">
                    <div class="modal-header border-bottom">
                        <h6 class="modal-title fw-bold">Requisition Details</h6>
                        <button class="btn-close" @onclick="CloseAllModals"></button>
                    </div>
                    <div class="modal-body p-5">

                        @if (selectedRequisition == null)
                        {
                            <div class="text-center py-5">
                                <div class="spinner-border text-primary"></div>
                                <p class="mt-3 text-muted">Loading requisition details...</p>
                            </div>
                        }
                        else
                        {
                            <!-- Header -->
                            <div class="d-flex align-items-center gap-4 border-bottom pb-3 mb-4">
                                <img src="/images/biit_logo.png" alt="BIIT Logo" style="max-width:80px;" />
                                <div>
                                    <h4 class="fw-bold mb-0">Barani Institute Of Information Technology</h4>
                                    <small class="text-muted">Official Event Requisition Application</small>
                                </div>
                            </div>

                            <!-- Subject + Dates -->
                            <div class="mb-4">
                                <p class="mb-1"><strong>Subject:</strong> @selectedRequisition.Subject</p>
                                <p class="mb-1"><strong>Requested Date:</strong> @selectedRequisition.RequestedDate.ToString("dd MMM yyyy")</p>
                                <p class="mb-0"><strong>Event Date:</strong> @selectedRequisition.EventDate.ToString("dd MMM yyyy")
                                </p>
                            </div>

                            <!-- Body -->
                            <div class="mb-4">
                                <p>Respected Sir,</p>
                                <p style="white-space:pre-line;">@selectedRequisition.Body</p>
                            </div>

                            <!-- Requirements -->
                            @if (selectedRequisition.EventRequirements != null && selectedRequisition.EventRequirements.Any())
                            {
                                <strong>@selectedRequisition.SocietyName Society need the following:</strong>
                                <div class="table-responsive mb-4 mt-2">
                                    <table class="table table-bordered align-middle">
                                        <thead class="table-light text-center">
                                            <tr>
                                                <th>Type</th>
                                                <th>Name</th>
                                                <th>Qty</th>
                                                <th>Unit Price</th>
                                                <th>Total</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var req in selectedRequisition.EventRequirements)
                                            {
                                                <tr>
                                                    <td>@req.Type</td>
                                                    <td>@req.Name</td>
                                                    <td class="text-center">@req.Quantity</td>
                                                    <td class="text-end">@req.Price.ToString("N2")</td>
                                                    <td class="text-end fw-semibold">@((req.Quantity * req.Price).ToString("N2"))</td>
                                                </tr>
                                            }
                                        </tbody>
                                        <tfoot class="table-light">
                                            <tr>
                                                <td colspan="4" class="text-end fw-bold">Total Requested Amount:</td>
                                                <td class="text-end fw-bold text-primary">
                                                    @TotalRequestedAmount.ToString("N2")
                                                </td>
                                            </tr>
                                        </tfoot>
                                    </table>
                                </div>
                            }
                            else
                            {
                                <p class="text-center text-muted">No requirements added for this event.</p>
                            }

                            <!-- Signature -->
                            <div class="mt-5 pt-4 border-top">
                                <p class="mb-1 fw-semibold">@selectedRequisition.ChairpersonName</p>
                                <p class="mb-4 text-muted">Chairperson (@selectedRequisition.SocietyName)</p>
                                <p class="mb-1 fw-semibold">Mr. Shahid Rashid</p>
                                <p class="text-muted">Assistant Director Student Affairs</p>
                            </div>
                        }

                    </div>
                    <div class="modal-footer border-top">
                        <button class="btn btn-secondary btn-sm" @onclick="CloseAllModals">Close</button>
                    </div>
                </div>
            </div>
        </div>
    }


@inject ClaimServices claimServices
@inject StudentAffairsServices studentAffairsServices
@inject IJSRuntime JS
@inject NavigationManager nav

@code {
    private bool loading = false;
    private Guid Id;

    private List<ViewRequisitionDetailsForStudentAffairsDto> approvedEventRequisitions = null!;
    private EventRequisitionDetailsDto? selectedRequisition = null;
    private decimal TotalRequestedAmount =>
        selectedRequisition?.EventRequirements.Sum(r => r.Price * r.Quantity) ?? 0;

    // ── Modal state ──────────────────────────────────────────
    private bool showStatusModal = false;
    private bool showReviewModal = false;
    private bool showViewModal = false;

    private string activeStatus = string.Empty;
    private string activeReviewMessage = string.Empty;

    // ── Init ─────────────────────────────────────────────────
    protected override async Task OnInitializedAsync()
    {
        loading = true;
        try
        {
            var claims = await claimServices.GetClaims();
            Id = Guid.Parse(claims.Id);
            var response = await studentAffairsServices.ViewApprovedRequisitionDetails();

            if (response != null)
                this.approvedEventRequisitions = response.ToList();
        }
        catch
        {
            await JS.InvokeVoidAsync("alert", "Something went wrong.");
        }
        finally
        {
            loading = false;
        }
    }

    // ── Modal Openers ────────────────────────────────────────
    private void OpenStatusModal(string status)
    {
        activeStatus = status;
        showStatusModal = true;
    }

    private void OpenReviewMessageModal(string message)
    {
        activeReviewMessage = message;
        showReviewModal = true;
    }

    private async Task OpenViewModal(Guid requisitionId)
    {
        selectedRequisition = null;
        showViewModal = true;
        try
        {
            selectedRequisition = await studentAffairsServices.ViewRequisitionRequestDetails(requisitionId);
        }
        catch
        {
            await JS.InvokeVoidAsync("alert", "Failed to load requisition details.");
        }
    }

    private void CloseAllModals()
    {
        showStatusModal = false;
        showReviewModal = false;
        showViewModal = false;
        selectedRequisition = null;
    }

    // -─ Handle Mark as Completed ───────────────────────────────
    private async Task HandleCompleted(Guid requisitionId)
    {
        bool confirm = await JS.InvokeAsync<bool>("confirm", "Are you sure you want to mark this event as completed?");
        if (!confirm)
            return;

        try
        {
            var responseResult = await studentAffairsServices.MarkEventAsCompleted(requisitionId);
            if (responseResult.Success)
            {
                await JS.InvokeVoidAsync("alert", "Event marked as completed.");
                nav.NavigateTo("/studentAffairs/approvedRequisitions");

                await OnInitializedAsync(); // Refresh data after completion
            }
            else
            {
                await JS.InvokeVoidAsync("alert", $"Failed to mark event as completed.{responseResult.Error}");
            }
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("alert", $"An error occurred while processing your request {ex.Message}.");
        }
    }

    // ── Helpers ──────────────────────────────────────────────
    private string GetStatusTextClass(string status) => status switch
    {
        var s when s.Contains("Reject", StringComparison.OrdinalIgnoreCase) => "text-danger",
        var s when s.Contains("Approved", StringComparison.OrdinalIgnoreCase) => "text-success",
        var s when s.Contains("Released", StringComparison.OrdinalIgnoreCase) => "text-primary",
        var s when s.Contains("Completed", StringComparison.OrdinalIgnoreCase) => "text-success",
        _ => "text-dark"
    };

    // ── Status Tracker Steps ─────────────────────────────────
    private record StatusStep(string Label, string SubLabel, string CircleColor, string Icon, string TextClass);

    private List<StatusStep> GetStatusSteps(string currentStatus)
    {
        bool saRejected = currentStatus == "Reject By Student Affairs";
        bool saApproved = currentStatus == "Approved By Student Affairs";
        bool adminRejected = currentStatus == "Reject By Admin";
        bool adminApproved = currentStatus == "Approved By Admin";
        bool financeRejected = currentStatus == "Reject By Finance";
        bool budgetReleased = currentStatus == "Budget Released By Finance";
        bool eventCompleted = currentStatus == "Event completed";

        // Step 1 — Requisition Submitted (Previously "Pending")
        StatusStep step1;
        if (saRejected || saApproved || adminRejected || adminApproved || financeRejected || budgetReleased || eventCompleted)
            step1 = new StatusStep("Requisition Submitted", "Requisition has been submitted.", "#198754", "bi-check-lg",
"text-success");
        else
            step1 = new StatusStep("Requisition Submitted", "Awaiting submission.", "#ced4da", "bi-hourglass-split", "text-muted");

        // Step 2 — Student Affairs
        StatusStep step2;
        if (saRejected)
            step2 = new StatusStep("Reject By Student Affairs", "Rejected at this stage.", "#dc3545", "bi-x-lg", "text-danger");
        else if (saApproved || adminApproved || adminRejected || financeRejected || budgetReleased || eventCompleted)
            step2 = new StatusStep("Approved By Student Affairs", "Approved and forwarded to Admin.", "#198754", "bi-check-lg",
"text-success");
        else if (currentStatus == "A" || string.IsNullOrEmpty(currentStatus))
            step2 = new StatusStep("Student Affairs Review", "Awaiting review by Student Affairs.", "#ffc107", "bi-clock",
"text-warning");
        else
            step2 = new StatusStep("Student Affairs Review", "Awaiting review by Student Affairs.", "#ced4da", "bi-clock",
"text-muted");

        // Step 3 — Admin
        StatusStep step3;
        if (adminRejected)
            step3 = new StatusStep("Reject By Admin", "Rejected by Admin.", "#dc3545", "bi-x-lg", "text-danger");
        else if (adminApproved || financeRejected || budgetReleased || eventCompleted)
            step3 = new StatusStep("Approved By Admin", "Approved by Admin.", "#198754", "bi-check-lg", "text-success");
        else if (saApproved)
            step3 = new StatusStep("Admin Review", "Awaiting Admin approval.", "#ffc107", "bi-clock", "text-warning");
        else
            step3 = new StatusStep("Admin Review", "Awaiting Admin approval.", "#ced4da", "bi-clock", "text-muted");

        // Step 4 — Finance
        StatusStep step4;
        if (financeRejected)
            step4 = new StatusStep("Reject By Finance", "Rejected by Finance department.", "#dc3545", "bi-x-lg", "text-danger");
        else if (budgetReleased || eventCompleted)
            step4 = new StatusStep("Budget Released By Finance", "Budget has been released.", "#0d6efd", "bi-cash-stack",
"text-primary");
        else if (adminApproved)
            step4 = new StatusStep("Finance Release", "Awaiting budget release by Finance.", "#ffc107", "bi-cash-stack",
"text-warning");
        else
            step4 = new StatusStep("Finance Release", "Awaiting budget release by Finance.", "#ced4da", "bi-cash-stack",
"text-muted");

        // Step 5 — Event Completion
        StatusStep step5;
        if (eventCompleted)
            step5 = new StatusStep("Event completed", "Event has been successfully completed.", "#198754", "bi-trophy",
"text-success");
        else if (budgetReleased)
            step5 = new StatusStep("Event Completion", "Ready to complete event.", "#ffc107", "bi-calendar-check", "text-warning");
        else
            step5 = new StatusStep("Event Completion", "Event pending completion.", "#ced4da", "bi-calendar-check", "text-muted");

        return new List<StatusStep> { step1, step2, step3, step4, step5 };
    }
}