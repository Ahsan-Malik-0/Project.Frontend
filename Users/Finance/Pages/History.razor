@page "/finance/history"

@layout FinanceLayout
@attribute [Authorize(Roles = "finance")]

@if (loading)
{
    <div class="text-center py-5">
        <div class="spinner-border text-primary"></div>
        <p class="mt-3 text-muted">Loading Requisitions...</p>
    </div>
}
else if (requisitionHistory.Count == 0)
{
    <div class="text-center py-5">
        <p class="text-muted fs-5">No approved requisitions available</p>
    </div>
}
else
{
    <h4 class="fw-bold mb-3">Approved Requisitions:</h4>
    <div class="row g-4">
        @foreach (var ph in requisitionHistory)
        {
            <div class="col-lg-4 col-md-6">
                <div class="card h-100 shadow-sm border">

                    <!-- Header -->
                    <div class="card-header">
                        <div class="d-flex justify-content-between align-items-center">
                            <h6 class="fw-bold mb-0">@ph.SocietyName</h6>
                        </div>
                    </div>

                    <!-- Body -->
                    <!-- Fix 1: card-body and card-footer are now properly separated -->
                    <div class="card-body">
                        <p class="text-muted small mb-2">
                            <strong>Event:</strong> @ph.EventName
                        </p>
                        <p class="text-muted small mb-2">
                            <strong>Chairperson:</strong> @(ph.ChairpersonName ?? "—")
                        </p>
                        <p class="text-muted small mb-2">
                            <strong>Event Date:</strong> @ph.EventDate.ToString("dd MMM yyyy")
                        </p>
                        <p class="text-muted small mb-2">
                            <strong>Alloted Budget:</strong>
                            <span class="fw-semibold text-primary">Rs @ph.AllotedBudget.ToString("N0")</span>
                        </p>
                        <p class="mb-2 small">
                            <strong class="text-muted">BIIT Contribution:</strong>
                            <span class="fw-semibold text-primary ms-1">Rs @ph.BiitContribution.ToString("N0")</span>
                        </p>
                        <p class="mb-2 small">
                            <strong class="text-muted">Total:</strong>
                            <span class="fw-semibold text-success ms-1">Rs @((ph.AllotedBudget + ph.BiitContribution).ToString("N0"))</span>
                        </p>
                        <p class="text-muted small mb-0">
                            <strong>Event Status:</strong>
                            @if (ph.Status.Contains("Released", StringComparison.CurrentCultureIgnoreCase))
                            {
                                <strong class="ms-1 @GetStatusTextClass(ph.Status)">Not Completed Yet</strong>
                            }
                            else
                            {
                                <strong class="ms-1 @GetStatusTextClass(ph.Status)">@ph.Status </strong>
                            }
                        </p>
                    </div>

                    <!-- Fix 1: card-footer is now outside card-body -->
                    <div class="card-footer bg-white border-top d-flex gap-2 py-3">
                        @* <button class="btn btn-outline-primary btn-sm flex-fill"
                                @onclick="() => OpenViewModal(ph.RequisitionId)">
                            <i class="bi bi-eye me-1"></i> View Requisition
                        </button> *@
                        <button class="btn btn-outline-secondary btn-sm flex-fill"
                                @onclick="() => OpenAuditModal(ph)">
                            <i class="bi bi-journal-text me-1"></i> View Audit
                        </button>
                    </div>

                </div>
            </div>
        }
    </div>
}


@* <!-- ===== MODAL: View Requisition ===== -->
@if (showViewModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background:rgba(0,0,0,0.5)">
        <div class="modal-dialog modal-xl modal-dialog-centered modal-dialog-scrollable">
            <div class="modal-content border-0 shadow">
                <div class="modal-header border-bottom">
                    <h6 class="modal-title fw-bold">Requisition Details</h6>
                    <button class="btn-close" @onclick="CloseAllModals"></button>
                </div>
                <div class="modal-body p-4">

                    @if (isLoadingDetails)
                    {
                        <div class="text-center py-4">
                            <div class="spinner-border spinner-border-sm mb-2"></div>
                            <p class="mb-0 text-muted">Loading details...</p>
                        </div>
                    }
                    else if (singleRequisitionDetails == null)
                    {
                        <p class="text-center text-muted">No details available.</p>
                    }
                    else
                    {
                        <div class="d-flex align-items-center gap-4 border-bottom pb-3 mb-4">
                            <img src="/images/biit_logo.png" alt="BIIT Logo" style="max-width:70px;" />
                            <div>
                                <h5 class="fw-bold mb-0">Barani Institute Of Information Technology</h5>
                                <small class="text-muted">Official Event Requisition Application</small>
                            </div>
                        </div>

                        <div class="mb-4">
                            <p class="mb-1"><strong>Subject:</strong> @singleRequisitionDetails.Subject</p>
                            <p class="mb-1"><strong>Requested Date:</strong> @singleRequisitionDetails.RequestedDate.ToString("dd MMM yyyy")</p>
                            <p class="mb-0"><strong>Event Date:</strong> @singleRequisitionDetails.EventDate.ToString("dd MMM yyyy")</p>
                        </div>

                        <div class="mb-4">
                            <p>Respected Sir,</p>
                            <p style="white-space:pre-line;">@singleRequisitionDetails.Body</p>
                        </div>

                        @if (singleRequisitionDetails.EventRequirements != null && singleRequisitionDetails.EventRequirements.Any())
                        {
                            <strong>@singleRequisitionDetails.SocietyName Society need the following:</strong>
                            <div class="table-responsive mb-4 mt-2">
                                <table class="table table-bordered align-middle">
                                    <thead class="table-light text-center">
                                        <tr>
                                            <th>Type</th>
                                            <th>Name</th>
                                            <th>Qty</th>
                                            <th>Unit Price</th>
                                            <th>Total</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var r in singleRequisitionDetails.EventRequirements)
                                        {
                                            <tr>
                                                <td>@r.Type</td>
                                                <td>@r.Name</td>
                                                <td class="text-center">@r.Quantity</td>
                                                <td class="text-end">@r.Price.ToString("N2")</td>
                                                <td class="text-end fw-semibold">@((r.Quantity * r.Price).ToString("N2"))</td>
                                            </tr>
                                        }
                                    </tbody>
                                    <tfoot class="table-light">
                                        <tr>
                                            <td colspan="4" class="text-end fw-bold">Total Requested Amount:</td>
                                            <td class="text-end fw-bold text-primary">
                                                @singleRequisitionDetails.EventRequirements.Sum(r => r.Quantity * r.Price).ToString("N2")
                                            </td>
                                        </tr>
                                    </tfoot>
                                </table>
                            </div>
                        }
                        else
                        {
                            <p class="text-center text-muted">No requirements added for this event.</p>
                        }

                        <div class="mt-5 pt-4 border-top">
                            <p class="mb-1 fw-semibold">@singleRequisitionDetails.ChairpersonName</p>
                            <p class="mb-4 text-muted">Chairperson (@singleRequisitionDetails.SocietyName)</p>
                            <p class="mb-1 fw-semibold">Mr. Shahid Rashid</p>
                            <p class="text-muted">Assistant Director Student Affairs</p>
                        </div>
                    }

                </div>
                <div class="modal-footer border-top">
                    <button class="btn btn-secondary btn-sm" @onclick="CloseAllModals">Close</button>
                </div>
            </div>
        </div>
    </div>
} *@


<!-- ===== MODAL: Audit ===== -->
@if (showAuditModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background:rgba(0,0,0,0.5)">
        <div class="modal-dialog modal-lg modal-dialog-centered modal-dialog-scrollable">
            <div class="modal-content border-0 shadow">
                <div class="modal-header border-bottom">
                    <h6 class="modal-title fw-bold">
                        <i class="bi bi-journal-text me-2"></i>Event Audit — @activeEventName
                    </h6>
                    <button class="btn-close" @onclick="CloseAllModals"></button>
                </div>

                <div class="modal-body">

                    @if (isLoadingAudit)
                    {
                        <div class="text-center py-4">
                            <div class="spinner-border spinner-border-sm mb-2"></div>
                            <p class="mb-0 text-muted">Loading audit...</p>
                        </div>
                    }
                    else if (activeAudit == null)
                    {
                        <div class="text-center py-5">
                            <i class="bi bi-journal-x fs-1 text-muted d-block mb-3"></i>
                            <p class="text-muted mb-2">Audit does not exist for this event.</p>

                            <!-- Fix 2: removed stray before variable inside -->
                            @if (activeEventStatus.Contains("Completed", StringComparison.OrdinalIgnoreCase))
                            {
                                <p class="text-muted small mb-3">
                                    The event is completed but no audit has been uploaded yet.
                                </p>
                                <button class="btn btn-outline-primary btn-sm px-4"
                                        @onclick="() => HandleAuditRequest(activeRequisitionId)">
                                    <i class="bi bi-bell me-1"></i> Ask for Audit
                                </button>
                            }
                            else if (activeEventStatus.Contains("Request", StringComparison.OrdinalIgnoreCase))
                            {
                                <p class="text-danger small mb-3">
                                    <i class="bi bi-exclamation-triangle me-1"></i>
                                    The chairperson has been requested for an audit but has not uploaded it yet.
                                </p>
                            }
                        </div>
                    }
                    else
                    {
                        <!-- Status Badge -->
                        <div class="text-center mb-4">
                            <span class="badge fs-6 px-4 py-2 @GetStatusBadgeClass(activeAudit.Status)">
                                <i class="bi @GetStatusIcon(activeAudit.Status) me-2"></i>
                                <!-- Fix 3: removed stray before variables inside -->
                                @if (activeAudit.Status == "give")
                                {
                                    <span>Collect</span>
                                }
                                else if (activeAudit.Status == "take")
                                {
                                    <span>Return</span>
                                }
                                else
                                {
                                    <span>@activeAudit.Status</span>
                                }
                            </span>

                            @if (activeAudit.Status == "give")
                            {
                                <div class="mt-3">
                                    <p class="text-danger small mb-2">
                                        <i class="bi bi-exclamation-circle me-1"></i>
                                        <!-- Fix 4: removed double on variable inside -->
                                        Collect <strong>Rs @((activeAudit.SpendAmount - activeAudit.FundProvided).ToString("N0"))</strong>
                                        from @(activeChairpersonName ?? "the Chairperson").
                                    </p>
                                    <!-- Fix 5: spinner now conditional, Fix 6: isActing added -->
                                    <button class="btn btn-success btn-sm px-4"
                                            disabled="@isActing"
                                            @onclick="VerifyTakeAmount">
                                        @if (isActing)
                                        {
                                            <span class="spinner-border spinner-border-sm me-1"></span>
                                        }
                                        <i class="bi bi-check-circle me-1"></i> Verify — Amount Collected
                                    </button>
                                </div>
                            }
                            else if (activeAudit.Status == "take")
                            {
                                <div class="alert alert-warning mt-3 py-2 small text-start">
                                    <i class="bi bi-exclamation-triangle me-1"></i>
                                    <!-- Fix 4: removed double -->
                                    Return <strong>Rs @((activeAudit.FundProvided - activeAudit.SpendAmount).ToString("N0"))</strong>
                                    to @(activeChairpersonName ?? "the Chairperson") as soon as possible.
                                </div>
                            }
                        </div>

                        <hr />

                        <!-- Audit Stats -->
                        <div class="row g-3 mb-4">
                            <div class="col-6 col-md-3">
                                <div class="bg-light rounded p-3 text-center">
                                    <div class="text-muted small mb-1" style="font-size:0.7rem;text-transform:uppercase;">Fund Provided</div>
                                    <div class="fw-bold text-primary">Rs @activeAudit.FundProvided.ToString("N0")</div>
                                </div>
                            </div>
                            <div class="col-6 col-md-3">
                                <div class="bg-light rounded p-3 text-center">
                                    <div class="text-muted small mb-1" style="font-size:0.7rem;text-transform:uppercase;">Amount Spent</div>
                                    <div class="fw-bold text-danger">Rs @activeAudit.SpendAmount.ToString("N0")</div>
                                </div>
                            </div>
                            <div class="col-6 col-md-3">
                                <div class="bg-light rounded p-3 text-center">
                                    <div class="text-muted small mb-1" style="font-size:0.7rem;text-transform:uppercase;">Revenue</div>
                                    <div class="fw-bold text-success">Rs @activeAudit.RevenueGenerated.ToString("N0")</div>
                                </div>
                            </div>
                            <div class="col-6 col-md-3">
                                <div class="bg-light rounded p-3 text-center">
                                    <div class="text-muted small mb-1" style="font-size:0.7rem;text-transform:uppercase;">Remaining</div>
                                    <div class="fw-bold">Rs @activeAudit.RemainingAmount.ToString("N0")</div>
                                </div>
                            </div>
                        </div>

                        <!-- Spends Table -->
                        @if (activeAudit.Spends != null && activeAudit.Spends.Any())
                        {
                            <h6 class="fw-semibold mb-3">Spend Details</h6>
                            <div class="table-responsive">
                                <table class="table table-bordered table-sm align-middle">
                                    <thead class="table-light">
                                        <tr>
                                            <th class="small">#</th>
                                            <th class="small">Vendor</th>
                                            <th class="small">Description</th>
                                            <th class="small text-end">Amount</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @{ int i = 1; }
                                        @foreach (var spend in activeAudit.Spends)
                                        {
                                            <tr>
                                                <td class="text-muted">@i</td>
                                                <td>@spend.Vender</td>
                                                <td class="text-muted small">@(spend.Description ?? "—")</td>
                                                <td class="text-end fw-semibold">Rs @spend.Amount.ToString("N0")</td>
                                            </tr>
                                            i++;
                                        }
                                    </tbody>
                                    <tfoot class="table-light">
                                        <tr>
                                            <td colspan="3" class="text-end fw-bold">Total Spent:</td>
                                            <td class="text-end fw-bold text-danger">
                                                Rs @activeAudit.Spends.Sum(s => s.Amount).ToString("N0")
                                            </td>
                                        </tr>
                                    </tfoot>
                                </table>
                            </div>
                        }
                    }

                </div>

                <div class="modal-footer border-top">
                    <button class="btn btn-secondary btn-sm" @onclick="CloseAllModals">Close</button>
                </div>

            </div>
        </div>
    </div>
}


@inject FinanceServices financeServices
@inject IJSRuntime JS

@code {
    private bool loading = false;
    private bool isLoadingAudit = false;
    private bool isLoadingDetails = false;
    private bool isActing = false;

    // Fix 7: initialize to new() to avoid NullReferenceException on .Count
    private List<ViewRequisitionDetailsForFinanceHistoryDto> requisitionHistory = new();
    private EventRequisitionDetailsDto? singleRequisitionDetails;

    // ── Modal flags ───────────────────────────────────────────
    private bool showAuditModal = false;
    private bool showViewModal = false;

    // ── Active selection ──────────────────────────────────────
    private Guid activeRequisitionId;
    private Guid activeEventId;
    private string activeEventName = "";
    private string activeChairpersonName = "";
    private string activeEventStatus = "";
    private EventAudit? activeAudit;

    // ── Init ──────────────────────────────────────────────────
    protected override async Task OnInitializedAsync()
    {
        loading = true;
        try
        {
            // Fix 8: removed unused claimServices call — finance history is not filtered by user
            var response = await financeServices.GetRequisitionHistory();
            requisitionHistory = response?.ToList() ?? new();
        }
        catch
        {
            await JS.InvokeVoidAsync("alert", "Something went wrong.");
        }
        finally
        {
            loading = false;
        }
    }

    // ── Modal Openers ─────────────────────────────────────────
    @* private async Task OpenViewModal(Guid requisitionId)
    {
        singleRequisitionDetails = null;
        showViewModal = true;
        isLoadingDetails = true;

        try
        {
            singleRequisitionDetails = await financeServices.GetRequisitionHistory(requisitionId);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading requisition: {ex.Message}");
        }
        finally
        {
            isLoadingDetails = false;
        }
    } *@

    private async Task OpenAuditModal(ViewRequisitionDetailsForFinanceHistoryDto item)
    {
        activeRequisitionId = item.RequisitionId;
        activeEventId = item.EventId;
        activeEventName = item.EventName;
        activeChairpersonName = item.ChairpersonName ?? "";
        activeEventStatus = item.Status;
        activeAudit = null;
        showAuditModal = true;
        isLoadingAudit = true;

        try
        {
            activeAudit = await financeServices.GetEventAudit(item.EventId);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading audit: {ex.Message}");
        }
        finally
        {
            isLoadingAudit = false;
        }
    }

    private void CloseAllModals()
    {
        showAuditModal = false;
        showViewModal = false;
        singleRequisitionDetails = null;
        activeAudit = null;
    }

    // ── Audit Actions ─────────────────────────────────────────
    private async Task VerifyTakeAmount()
    {
        if (activeAudit == null) return;

        bool confirm = await JS.InvokeAsync<bool>("confirm", "Confirm that you have collected the amount from the chairperson?");
        if (!confirm) return;

        // Fix 6: isActing properly set to show spinner and disable button
        isActing = true;
        try
        {
            var response = await financeServices.VerifyTakeAmount(activeAudit.Id);
            if (response.Success)
            {
                activeAudit.Status = "clear";
                await JS.InvokeVoidAsync("alert", "Status updated to Clear.");

                await OnInitializedAsync(); // Refresh the history to update the status of the event
            }
            else
            {
                await JS.InvokeVoidAsync("alert", $"Failed: {response?.Error}");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error verifying: {ex.Message}");
        }
        finally
        {
            isActing = false;
        }
    }

    private async Task HandleAuditRequest(Guid requisitionId)
    {
        bool confirm = await JS.InvokeAsync<bool>("confirm", "Send an audit request to the chairperson for this event?");
        if (!confirm) return;

        try
        {
            var response = await financeServices.RequestAudit(requisitionId);
            if (response.Success)
            {
                await JS.InvokeVoidAsync("alert", "Audit request sent successfully.");
                showAuditModal = false;

                await OnInitializedAsync(); // Refresh the history to update the status of the event
            }
            else
            {
                await JS.InvokeVoidAsync("alert", $"Failed to send request: {response?.Error}");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error requesting audit: {ex.Message}");
            await JS.InvokeVoidAsync("alert", "An error occurred while sending the request.");
        }
    }

    // ── Helpers ───────────────────────────────────────────────
    private string GetStatusTextClass(string status) => status switch
    {
        var s when s.Contains("Released", StringComparison.OrdinalIgnoreCase)  => "text-dark",
        var s when s.Contains("Completed", StringComparison.OrdinalIgnoreCase) => "text-dark",
        var s when s.Contains("Request", StringComparison.OrdinalIgnoreCase) => "text-warning",
        var s when s.Contains("Cleared", StringComparison.OrdinalIgnoreCase) => "text-success",
        _ => "text-dark"
    };

    private string GetStatusBadgeClass(string? status) => status switch
    {
        "clear" => "bg-success",
        "give"  => "bg-danger",
        "take"  => "bg-warning text-dark",
        _       => "bg-secondary"
    };

    private string GetStatusIcon(string? status) => status switch
    {
        "clear" => "bi-check-circle-fill",
        "give"  => "bi-arrow-down-circle-fill",
        "take"  => "bi-arrow-up-circle-fill",
        _       => "bi-question-circle"
    };
}
