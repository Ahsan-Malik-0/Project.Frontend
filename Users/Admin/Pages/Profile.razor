@page "/admin/profile"
@layout AdminLayout
@attribute [Authorize(Roles = "admin")]

<SharedProfile Id=@Id />

@inject ClaimServices claimServices
@code {
    public Guid Id;

    protected override async Task OnInitializedAsync()
    {
        var claims = await claimServices.GetClaims();
        Id = Guid.Parse(claims.Id);
    }
}